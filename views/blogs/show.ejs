<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= blog.title %> - ATOM Game Shop</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .blog-content img {
      max-width: 100%;
      height: auto;
    }
  </style>
</head>
<body>
  <!-- Navigation -->
  <%- include('../partials/navbar') %>

  <!-- Main Content -->
  <main class="container mt-5">
    <div class="row">
      <!-- Blog Content -->
      <div class="col-lg-8">
        <article>
          <% if (blog.image_path) { %>
            <img src="<%= blog.image_path %>" class="img-fluid rounded mb-4 w-100" alt="<%= blog.title %>" style="max-height: 400px; object-fit: cover;">
          <% } %>
          
          <h1 class="display-4 mb-3"><%= blog.title %></h1>
          
          <div class="d-flex align-items-center mb-4 text-muted">
            <span class="me-3"><i class="bi bi-calendar"></i> <%= new Date(blog.created_at).toLocaleDateString() %></span>
            <span><i class="bi bi-eye"></i> <%= blog.views %> views</span>
          </div>
          
          <div class="blog-content">
            <%- blog.content %>
          </div>
        </article>

        <hr class="my-5">

        <div class="text-center">
          <a href="/blogs" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Blogs
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="col-lg-4 mt-5 mt-lg-0">
        <div class="card shadow-sm sticky-top" style="top: 80px; z-index: 10;">
          <div class="card-header bg-primary text-white">
            <h5 class="card-title mb-0">Recent Posts</h5>
          </div>
          <div class="list-group list-group-flush">
            <% if (recentBlogs.length > 0) { %>
              <% recentBlogs.forEach(recent => { %>
                <a href="/blogs/<%= recent.slug %>" class="list-group-item list-group-item-action d-flex align-items-center">
                  <% if (recent.image_path) { %>
                    <img src="<%= recent.image_path %>" alt="<%= recent.title %>" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;">
                  <% } else { %>
                    <div class="rounded me-3 bg-secondary d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                      <i class="bi bi-image text-white"></i>
                    </div>
                  <% } %>
                  <div>
                    <h6 class="mb-0 text-truncate" style="max-width: 200px;"><%= recent.title %></h6>
                    <small class="text-muted"><%= new Date(recent.created_at).toLocaleDateString() %></small>
                  </div>
                </a>
              <% }); %>
            <% } else { %>
              <div class="list-group-item text-center text-muted">
                No recent posts
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="bg-dark text-white text-center py-3 mt-5">
    <div class="container">
      <p class="mb-0">&copy; <%= new Date().getFullYear() %> ATOM Game Shop. All rights reserved.</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
