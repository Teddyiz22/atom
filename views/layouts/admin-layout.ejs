  <script>
    (function() {
      var mobileSidebar = document.getElementById('mobile-sidebar');
      var mobileOverlay = document.getElementById('mobile-sidebar-overlay');
      var mobileClose = document.getElementById('mobile-sidebar-close');

      function openMobileSidebar() {
        if (window.innerWidth < 768) {
          mobileSidebar.classList.add('mobile-sidebar-open');
          mobileOverlay.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
          document.body.style.position = 'fixed';
          document.body.style.width = '100%';
        }
      }

      function closeMobileSidebar() {
        if (window.innerWidth < 768) {
          mobileSidebar.classList.remove('mobile-sidebar-open');
          mobileOverlay.classList.add('hidden');
          document.body.style.overflow = '';
          document.body.style.position = '';
          document.body.style.width = '';
        }
      }

      closeMobileSidebar();

      var toggle = document.getElementById('sidebar-toggle');
      if (toggle) {
        toggle.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var isOpen = mobileSidebar.classList.contains('mobile-sidebar-open');
          if (isOpen) closeMobileSidebar();
          else openMobileSidebar();
        });
      }

      if (mobileClose) {
        mobileClose.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          closeMobileSidebar();
        });
      }

      if (mobileOverlay) {
        mobileOverlay.addEventListener('click', function(e) {
          e.preventDefault();
          closeMobileSidebar();
        });
      }

      window.addEventListener('resize', function() {
        if (window.innerWidth >= 768) {
          closeMobileSidebar();
        }
      });

      (function() {
        var path = window.location.pathname || '';
        var groups = [
          { key: 'overview', links: ['/admin', '/admin/reports'] },
          { key: 'management', links: ['/admin/users', '/admin/product-management', '/admin/product-types', '/admin/payment-methods', '/admin/smile-sub-items', '/admin/g2bulk-items'] },
          { key: 'finance', links: ['/admin/wallets', '/admin/transactions', '/admin/game-purchase-transactions'] },
          { key: 'settings', links: ['/admin/settings'] }
        ];

        var expandKey = '';
        for (var i = 0; i < groups.length; i++) {
          var g = groups[i];
          for (var j = 0; j < g.links.length; j++) {
            var h = g.links[j];
            if (path === h || (path.startsWith(h) && h !== '/admin')) { expandKey = g.key; break; }
          }
          if (expandKey) break;
        }
        var saved = localStorage.getItem('sidebar.expanded') || '';
        var defaultExpand = expandKey || saved || 'overview';

        var parents = document.querySelectorAll('#mobile-sidebar [data-parent-key]');
        for (var p = 0; p < parents.length; p++) {
          var key = parents[p].getAttribute('data-parent-key');
          var children = document.querySelector('#mobile-sidebar [data-children-of="' + key + '"]');
          var chev = parents[p].querySelector('[data-chevron]');
          if (key === defaultExpand && children) {
            children.classList.remove('hidden');
            if (chev) chev.classList.add('rotate-180');
          }
          parents[p].addEventListener('click', function(e) {
            var btn = e.currentTarget;
            var k = btn.getAttribute('data-parent-key');
            var c = document.querySelector('#mobile-sidebar [data-children-of="' + k + '"]');
            var ch = btn.querySelector('[data-chevron]');
            if (!c) return;
            var hidden = c.classList.contains('hidden');
            document.querySelectorAll('#mobile-sidebar [data-children-of]').forEach(function(el) { el.classList.add('hidden'); });
            document.querySelectorAll('#mobile-sidebar [data-chevron]').forEach(function(el) { el.classList.remove('rotate-180'); });
            if (hidden) {
              c.classList.remove('hidden');
              if (ch) ch.classList.add('rotate-180');
              localStorage.setItem('sidebar.expanded', k);
            } else {
              c.classList.add('hidden');
              if (ch) ch.classList.remove('rotate-180');
              localStorage.removeItem('sidebar.expanded');
            }
          });
        }

        var links = document.querySelectorAll('#mobile-sidebar nav a');
        for (var x = 0; x < links.length; x++) {
          var href = links[x].getAttribute('href');
          if (href === path || (path.startsWith(href) && href !== '/admin')) {
            links[x].classList.add('bg-gradient-to-r','from-blue-600','to-purple-600','font-semibold','text-white','shadow-md');
            links[x].classList.remove('text-gray-400','hover:text-white');
            var parent = links[x].closest('[data-children-of]');
            if (parent) {
              var parentKey = parent.getAttribute('data-children-of');
              var parentBtn = document.querySelector('#mobile-sidebar [data-parent-key="' + parentKey + '"]');
              if (parentBtn) {
                var span = parentBtn.querySelector('span');
                if (span) span.classList.add('text-white');
              }
            }
          }
          links[x].addEventListener('click', function() {
            closeMobileSidebar();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      })();
    })();
  </script>

  <script src="/admin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/admin/vendor/jquery-easing/jquery.easing.min.js"></script>
  <script src="/admin/js/sb-admin-2.min.js"></script>
  <script src="/admin/vendor/chart.js/Chart.min.js"></script>
  <script src="/admin/vendor/datatables/jquery.dataTables.min.js"></script>
  <script src="/admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>

  <%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
