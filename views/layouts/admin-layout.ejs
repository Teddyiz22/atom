      <script>
        (function() {
          var path = window.location.pathname || '';
          var groups = [
            { key: 'overview', links: ['/admin', '/admin/reports'] },
            { key: 'management', links: ['/admin/users', '/admin/product-management', '/admin/product-types', '/admin/payment-methods', '/admin/smile-sub-items', '/admin/g2bulk-items', '/admin/blogs'] },
            { key: 'finance', links: ['/admin/wallets', '/admin/wallets/active', '/admin/transactions', '/admin/game-purchase-transactions'] },
            { key: 'settings', links: ['/admin/settings'] }
          ];

          var expandKey = '';
          for (var i = 0; i < groups.length; i++) {
            var g = groups[i];
            for (var j = 0; j < g.links.length; j++) {
              var h = g.links[j];
              if (path === h || (path.startsWith(h) && h !== '/admin')) { expandKey = g.key; break; }
            }
            if (expandKey) break;
          }
          var saved = localStorage.getItem('sidebar.expanded') || '';
          var defaultExpand = expandKey || saved || 'overview';

          var parents = document.querySelectorAll('#sidebar [data-parent-key]');
          for (var k = 0; k < parents.length; k++) {
            var key = parents[k].getAttribute('data-parent-key');
            var children = document.querySelector('#sidebar [data-children-of="' + key + '"]');
            var chev = parents[k].querySelector('[data-chevron]');
            if (key === defaultExpand && children) {
              children.classList.remove('hidden');
              if (chev) chev.classList.add('rotate-180');
            }
            parents[k].addEventListener('click', function(e) {
              var p = e.currentTarget;
              var kk = p.getAttribute('data-parent-key');
              var c = document.querySelector('#sidebar [data-children-of="' + kk + '"]');
              var ch = p.querySelector('[data-chevron]');
              if (!c) return;
              var hidden = c.classList.contains('hidden');
              document.querySelectorAll('#sidebar [data-children-of]').forEach(function(el) { el.classList.add('hidden'); });
              document.querySelectorAll('#sidebar [data-chevron]').forEach(function(el) { el.classList.remove('rotate-180'); });
              if (hidden) {
                c.classList.remove('hidden');
                if (ch) ch.classList.add('rotate-180');
                localStorage.setItem('sidebar.expanded', kk);
              } else {
                c.classList.add('hidden');
                if (ch) ch.classList.remove('rotate-180');
                localStorage.removeItem('sidebar.expanded');
              }
            });
          }

          var links = document.querySelectorAll('#sidebar nav a');
          for (var x = 0; x < links.length; x++) {
            var href = links[x].getAttribute('href');
            if (href === path || (path.startsWith(href) && href !== '/admin')) {
              links[x].classList.add('bg-gradient-to-r','from-blue-600','to-purple-600','font-semibold','text-white','shadow-md');
              links[x].classList.remove('text-gray-400','hover:text-white');
              var parent = links[x].closest('[data-children-of]');
              if (parent) {
                var parentKey = parent.getAttribute('data-children-of');
                var parentBtn = document.querySelector('#sidebar [data-parent-key="' + parentKey + '"]');
                if (parentBtn) {
                  var span = parentBtn.querySelector('span');
                  if (span) span.classList.add('text-white');
                }
              }
            }
            links[x].addEventListener('click', function() {
              window.scrollTo({ top: 0, behavior: 'smooth' });
            });
          }
          if (window.scrollY > 0) {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        })();
      </script>
