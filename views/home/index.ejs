  </div> -->

  <!-- Main Content -->
  <main class="container mt-4">
    <!-- Flash Messages -->
    <%- include('../partials/messages') %>

    <!-- Hero Section -->
    <div class="jumbotron bg-primary text-white p-5 rounded mb-4">
      <div class="container-fluid py-5">
        <h1 class="display-5 fw-bold">Welcome to ATOM Game Shop</h1>
        <p class="col-md-8 fs-4">Your one-stop destination for quality products and exceptional service. Discover
          amazing deals and explore our wide range of products.</p>
        <% if (!user) { %>
        <a href="/users/register" class="btn btn-outline-light btn-lg">Get Started</a>
        <% } else { %>
        <p class="fs-5">Welcome back, <%= user.name %>! 👋</p>
        <% } %>
      </div>
    </div>

    <!-- Features Section -->
    <div class="row mb-5">
      <div class="col-lg-4 mb-4">
        <div class="card h-100">
          <div class="card-body text-center">
            <i class="bi bi-lightning-charge text-primary" style="font-size: 3rem;"></i>
            <h5 class="card-title mt-3">Fast Delivery</h5>
            <p class="card-text">Get your orders delivered quickly with our express shipping options.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4 mb-4">
        <div class="card h-100">
          <div class="card-body text-center">
            <i class="bi bi-shield-check text-success" style="font-size: 3rem;"></i>
            <h5 class="card-title mt-3">Secure Shopping</h5>
            <p class="card-text">Shop with confidence knowing your data is protected with industry-standard
              security.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4 mb-4">
        <div class="card h-100">
          <div class="card-body text-center">
            <i class="bi bi-headset text-info" style="font-size: 3rem;"></i>
            <h5 class="card-title mt-3">24/7 Support</h5>
            <p class="card-text">Our customer support team is always ready to help you with any questions.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Section -->
    <div class="row text-center mb-5">
      <div class="col-md-3 mb-3">
        <div class="card border-0">
          <div class="card-body">
            <h2 class="text-primary">1000+</h2>
            <p class="card-text">Happy Customers</p>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="card border-0">
          <div class="card-body">
            <h2 class="text-success">500+</h2>
            <p class="card-text">Products Available</p>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="card border-0">
          <div class="card-body">
            <h2 class="text-warning">99.9%</h2>
            <p class="card-text">Uptime</p>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="card border-0">
          <div class="card-body">
            <h2 class="text-info">24/7</h2>
            <p class="card-text">Support Available</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <%- include('../partials/footer') %>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Custom JS -->
  <script src="/js/main.js"></script>
</body>

</html>