<!-- Page Heading -->
<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <h1 class="h3 mb-0 text-gray-800">
    <i class="fas fa-box"></i> Product Management
  </h1>
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
      <li class="breadcrumb-item active">Products</li>
    </ol>
  </nav>
</div>

<!-- Custom CSS for purple badge -->
<style>
  .badge-purple {
    color: #fff;
    background-color: #6f42c1;
  }

  .text-purple {
    color: #6f42c1 !important;
  }
</style>

<div class="container-fluid">
  <!-- Page Heading -->
  <div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
      <i class="fas fa-gem"></i> Product Management
    </h1>
    <a href="/admin/products/new" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
      <i class="fas fa-plus fa-sm text-white-50"></i> Add New Product
    </a>
  </div>

  <!-- Filters and Search -->
  <div class="card shadow mb-4">
    <div class="card-header py-3">
      <h6 class="m-0 font-weight-bold text-primary">
        <i class="fas fa-filter"></i> Filters & Search
      </h6>
    </div>
    <div class="card-body">
      <form method="GET" action="/admin/products" class="row">
        <div class="col-md-3">
          <div class="form-group">
            <label for="category">Category</label>
            <select class="form-control" id="category" name="category">
              <option value="all" <%=filters.category==='all' ? 'selected' : '' %>>All Categories</option>
              <option value="DIAMOND" <%=filters.category==='DIAMOND' ? 'selected' : '' %>>Diamond Packages</option>
              <option value="WEEKLY_PASS" <%=filters.category==='WEEKLY_PASS' ? 'selected' : '' %>>Weekly Pass</option>
              <option value="TWILIGHT_PASS" <%=filters.category==='TWILIGHT_PASS' ? 'selected' : '' %>>Twilight Pass
              </option>
              <option value="DOUBLE_DIAMOND" <%=filters.category==='DOUBLE_DIAMOND' ? 'selected' : '' %>>Double Diamond
              </option>
            </select>
          </div>
        </div>
        <div class="col-md-3">
          <div class="form-group">
            <label for="status">Status</label>
            <select class="form-control" id="status" name="status">
              <option value="all" <%=filters.status==='all' ? 'selected' : '' %>>All Status</option>
              <option value="active" <%=filters.status==='active' ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%=filters.status==='inactive' ? 'selected' : '' %>>Inactive</option>
            </select>
          </div>
        </div>
        <div class="col-md-4">
          <div class="form-group">
            <label for="search">Search</label>
            <input type="text" class="form-control" id="search" name="search" value="<%= filters.search %>"
              placeholder="Search by name or description...">
          </div>
        </div>
        <div class="col-md-2">
          <div class="form-group">
            <label>&nbsp;</label>
            <div>
              <button type="submit" class="btn btn-primary btn-block">
                <i class="fas fa-search"></i> Filter
              </button>
            </div>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Products Table -->
  <div class="card shadow mb-4">
    <div class="card-header py-3">
      <div class="row align-items-center">
        <div class="col">
          <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-list"></i> Products List
            <% if (pagination && pagination.totalItems) { %>
              <small class="text-muted">(<%= pagination.totalItems %> total)</small>
              <% } %>
          </h6>
        </div>
        <div class="col-auto">
          <div class="dropdown">
            <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-toggle="dropdown"
              aria-haspopup="true" aria-expanded="false">
              <i class="fas fa-sort"></i> Sort
            </button>
            <div class="dropdown-menu">
              <a class="dropdown-item"
                href="?sort=name&order=ASC&category=<%= filters.category %>&status=<%= filters.status %>&search=<%= filters.search %>">
                Name (A-Z)
              </a>
              <a class="dropdown-item"
                href="?sort=name&order=DESC&category=<%= filters.category %>&status=<%= filters.status %>&search=<%= filters.search %>">
                Name (Z-A)
              </a>
              <a class="dropdown-item"
                href="?sort=diamond_amount&order=ASC&category=<%= filters.category %>&status=<%= filters.status %>&search=<%= filters.search %>">
                Diamonds (Low to High)
              </a>
              <a class="dropdown-item"
                href="?sort=diamond_amount&order=DESC&category=<%= filters.category %>&status=<%= filters.status %>&search=<%= filters.search %>">
                Diamonds (High to Low)
              </a>
              <a class="dropdown-item"
                href="?sort=price_mmk&order=ASC&category=<%= filters.category %>&status=<%= filters.status %>&search=<%= filters.search %>">
                Price (Low to High)
              </a>
              <a class="dropdown-item"
                href="?sort=price_mmk&order=DESC&category=<%= filters.category %>&status=<%= filters.status %>&search=<%= filters.search %>">
                Price (High to Low)
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% if (products && products.length> 0) { %>
      <!-- Bulk Actions -->
      <div class="card-body border-bottom">
        <div class="row align-items-center">
          <div class="col-md-6">
            <div class="form-inline">
              <input type="checkbox" id="selectAll" class="mr-2">
              <label for="selectAll" class="mr-3">Select All</label>
              <select class="form-control form-control-sm mr-2" id="bulkAction">
                <option value="">Choose Action...</option>
                <option value="activate">Activate Selected</option>
                <option value="deactivate">Deactivate Selected</option>
                <option value="feature">Mark as Featured</option>
                <option value="unfeature">Remove from Featured</option>
              </select>
              <button type="button" class="btn btn-sm btn-primary" id="applyBulkAction">
                Apply
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="table-responsive">
        <table class="table table-bordered" width="100%" cellspacing="0">
          <thead>
            <tr>
              <th width="3%">
                <input type="checkbox" id="selectAllHeader">
              </th>
              <th width="5%">ID</th>
              <th width="25%">Product</th>
              <th width="12%">Category</th>
              <th width="10%">Diamonds</th>
              <th width="10%">Price (MMK)</th>
              <th width="10%">Price (THB)</th>
              <th width="8%">Status</th>
              <th width="8%">Featured</th>
              <th width="9%">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(product=> { %>
              <tr data-product-id="<%= product.id %>">
                <td>
                  <input type="checkbox" class="product-checkbox" value="<%= product.id %>">
                </td>
                <td>
                  <%= product.id %>
                </td>
                <td>
                  <div class="d-flex align-items-center">
                    <div class="mr-3">
                      <% if (product.category==='DIAMOND' ) { %>
                        <i class="fas fa-gem text-primary fa-lg"></i>
                        <% } else if (product.category==='WEEKLY_PASS' ) { %>
                          <i class="fas fa-calendar-week text-success fa-lg"></i>
                          <% } else if (product.category==='TWILIGHT_PASS' ) { %>
                            <i class="fas fa-moon text-info fa-lg"></i>
                            <% } else if (product.category==='DOUBLE_DIAMOND' ) { %>
                              <i class="fas fa-gems text-purple fa-lg"></i>
                              <% } else { %>
                                <i class="fas fa-star text-warning fa-lg"></i>
                                <% } %>
                    </div>
                    <div>
                      <div class="font-weight-bold">
                        <%= product.name %>
                      </div>
                      <% if (product.description) { %>
                        <small class="text-muted">
                          <%= product.description.substring(0, 50) %>
                            <%= product.description.length> 50 ? '...' : '' %>
                        </small>
                        <% } %>
                    </div>
                  </div>
                </td>
                <td>
                  <% if (product.category==='DIAMOND' ) { %>
                    <span class="badge badge-primary">Diamond</span>
                    <% } else if (product.category==='WEEKLY_PASS' ) { %>
                      <span class="badge badge-success">Weekly Pass</span>
                      <% } else if (product.category==='TWILIGHT_PASS' ) { %>
                        <span class="badge badge-info">Twilight Pass</span>
                        <% } else if (product.category==='DOUBLE_DIAMOND' ) { %>
                          <span class="badge badge-purple">Double Diamond</span>
                          <% } else { %>
                            <span class="badge badge-warning">Other</span>
                            <% } %>
                </td>
                <td>
                  <div class="text-center">
                    <div class="font-weight-bold text-primary">
                      <%= product.diamond_amount %>
                    </div>
                  </div>
                </td>
                <td>
                  <div class="text-right">
                    <div class="font-weight-bold">
                      <%= new Intl.NumberFormat('en-US').format(product.price_mmk) %>
                    </div>
                  </div>
                </td>
                <td>
                  <div class="text-right">
                    <div class="font-weight-bold">
                      ฿<%= new Intl.NumberFormat('en-US').format(product.price_thb) %>
                    </div>
                  </div>
                </td>
                <td class="text-center">
                  <button type="button"
                    class="btn btn-sm <%= product.is_active ? 'btn-success' : 'btn-danger' %> toggle-status"
                    data-product-id="<%= product.id %>" data-product-name="<%= product.name %>">
                    <i class="fas <%= product.is_active ? 'fa-check' : 'fa-times' %>"></i>
                    <%= product.is_active ? 'Active' : 'Inactive' %>
                  </button>
                </td>
                <td class="text-center">
                  <% if (product.is_featured) { %>
                    <i class="fas fa-star text-warning" title="Featured"></i>
                    <% } else { %>
                      <i class="far fa-star text-muted" title="Not Featured"></i>
                      <% } %>
                </td>
                <td>
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                      data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                      <i class="fas fa-cog"></i>
                    </button>
                    <div class="dropdown-menu">
                      <a class="dropdown-item" href="/admin/products/<%= product.id %>">
                        <i class="fas fa-eye"></i> View Details
                      </a>
                      <a class="dropdown-item" href="/admin/products/<%= product.id %>/edit">
                        <i class="fas fa-edit"></i> Edit
                      </a>
                      <div class="dropdown-divider"></div>
                      <button class="dropdown-item toggle-status" data-product-id="<%= product.id %>"
                        data-product-name="<%= product.name %>">
                        <i class="fas <%= product.is_active ? 'fa-times text-danger' : 'fa-check text-success' %>"></i>
                        <%= product.is_active ? 'Deactivate' : 'Activate' %>
                      </button>
                    </div>
                  </div>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (pagination.totalPages> 1) { %>
        <nav aria-label="Products pagination">
          <ul class="pagination justify-content-center">
            <% if (pagination.hasPrevPage) { %>
              <li class="page-item">
                <a class="page-link"
                  href="?page=<%= pagination.currentPage - 1 %>&category=<%= filters.category %>&status=<%= filters.status %>&search=<%= filters.search %>&sort=<%= filters.sort %>&order=<%= filters.order %>">
                  Previous
                </a>
              </li>
              <% } %>

                <% for (let i=Math.max(1, pagination.currentPage - 2); i <=Math.min(pagination.totalPages,
                  pagination.currentPage + 2); i++) { %>
                  <li class="page-item <%= i === pagination.currentPage ? 'active' : '' %>">
                    <a class="page-link"
                      href="?page=<%= i %>&category=<%= filters.category %>&status=<%= filters.status %>&search=<%= filters.search %>&sort=<%= filters.sort %>&order=<%= filters.order %>">
                      <%= i %>
                    </a>
                  </li>
                  <% } %>

                    <% if (pagination.hasNextPage) { %>
                      <li class="page-item">
                        <a class="page-link"
                          href="?page=<%= pagination.currentPage + 1 %>&category=<%= filters.category %>&status=<%= filters.status %>&search=<%= filters.search %>&sort=<%= filters.sort %>&order=<%= filters.order %>">
                          Next
                        </a>
                      </li>
                      <% } %>
          </ul>
        </nav>

        <div class="text-center text-muted">
          Showing <%= (pagination.currentPage - 1) * pagination.limit + 1 %> to
            <%= Math.min(pagination.currentPage * pagination.limit, pagination.totalItems) %> of
              <%= pagination.totalItems %> products
        </div>
        <% } %>

          <% } else { %>
            <div class="text-center py-5">
              <i class="fas fa-gem fa-3x text-muted mb-3"></i>
              <h5 class="text-muted">No products found</h5>
              <p class="text-muted">Try adjusting your search criteria or add some products.</p>
              <a href="/admin/products/new" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add New Product
              </a>
            </div>
            <% } %>
  </div>
</div>

<!-- JavaScript for Product Management -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Select All functionality
    const selectAllCheckbox = document.getElementById('selectAll');
    const selectAllHeaderCheckbox = document.getElementById('selectAllHeader');
    const productCheckboxes = document.querySelectorAll('.product-checkbox');

    // Sync both select all checkboxes
    [selectAllCheckbox, selectAllHeaderCheckbox].forEach(checkbox => {
      if (checkbox) {
        checkbox.addEventListener('change', function () {
          const isChecked = this.checked;
          productCheckboxes.forEach(productCheckbox => {
            productCheckbox.checked = isChecked;
          });
          // Sync the other select all checkbox
          if (selectAllCheckbox && selectAllHeaderCheckbox) {
            selectAllCheckbox.checked = isChecked;
            selectAllHeaderCheckbox.checked = isChecked;
          }
        });
      }
    });

    // Update Select All when individual checkboxes change
    productCheckboxes.forEach(checkbox => {
      checkbox.addEventListener('change', function () {
        const checkedCount = document.querySelectorAll('.product-checkbox:checked').length;
        const totalCount = productCheckboxes.length;

        [selectAllCheckbox, selectAllHeaderCheckbox].forEach(selectAllBox => {
          if (selectAllBox) {
            selectAllBox.checked = checkedCount === totalCount;
            selectAllBox.indeterminate = checkedCount > 0 && checkedCount < totalCount;
          }
        });
      });
    });

    // Toggle Status functionality
    document.querySelectorAll('.toggle-status').forEach(button => {
      button.addEventListener('click', function () {
        const productId = this.dataset.productId;
        const productName = this.dataset.productName;

        if (confirm(`Are you sure you want to toggle the status of "${productName}"?`)) {
          fetch(`/admin/products/${productId}/toggle-status`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          })
            .then(response => response.json())
            .then(data => {
              if (data.success) {
                showSuccessToast(data.message);
                // Reload page to reflect changes
                setTimeout(() => {
                  window.location.reload();
                }, 1000);
              } else {
                showErrorToast(data.message);
              }
            })
            .catch(error => {
              console.error('Error:', error);
              showErrorToast('Failed to update product status');
            });
        }
      });
    });

    // Bulk Actions functionality
    const applyBulkActionBtn = document.getElementById('applyBulkAction');
    if (applyBulkActionBtn) {
      applyBulkActionBtn.addEventListener('click', function () {
        const selectedAction = document.getElementById('bulkAction').value;
        const selectedProducts = Array.from(document.querySelectorAll('.product-checkbox:checked'))
          .map(checkbox => checkbox.value);

        if (!selectedAction) {
          showWarningToast('Please select an action');
          return;
        }

        if (selectedProducts.length === 0) {
          showWarningToast('Please select at least one product');
          return;
        }

        const actionNames = {
          'activate': 'activate',
          'deactivate': 'deactivate',
          'feature': 'mark as featured',
          'unfeature': 'remove from featured'
        };

        if (confirm(`Are you sure you want to ${actionNames[selectedAction]} ${selectedProducts.length} products?`)) {
          fetch('/admin/products/bulk-action', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              action: selectedAction,
              productIds: selectedProducts
            })
          })
            .then(response => response.json())
            .then(data => {
              if (data.success) {
                showSuccessToast(data.message);
                // Reload page to reflect changes
                setTimeout(() => {
                  window.location.reload();
                }, 1000);
              } else {
                showErrorToast(data.message);
              }
            })
            .catch(error => {
              console.error('Error:', error);
              showErrorToast('Failed to perform bulk action');
            });
        }
      });
    }
  });
</script>
