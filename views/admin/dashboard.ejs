<div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-white">Dashboard</h2>
      <p class="text-sm text-gray-300">Overview of users and system status</p>
    </div>
    <div class="flex items-center gap-3">
      <a href="/" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-sm font-semibold text-gray-100 transition-colors">
        <svg class="h-4 w-4 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Website
      </a>
    </div>
  </div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-6">
    <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-xl shadow-lg p-5 text-white">
      <div class="flex items-start justify-between">
        <div>
          <div class="text-sm font-semibold opacity-90">Total Users</div>
          <div class="text-3xl font-bold mt-2"><%= stats.totalUsers %></div>
        </div>
        <div class="p-3 bg-white/15 rounded-xl">
          <svg class="h-6 w-6 opacity-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-4-4h-1M9 20H4v-2a4 4 0 014-4h1m8-4a4 4 0 10-8 0 4 4 0 008 0z" />
          </svg>
        </div>
      </div>
      <div class="text-xs opacity-75 mt-3">Registered accounts</div>
    </div>

    <div class="bg-gradient-to-br from-emerald-600 to-teal-700 rounded-xl shadow-lg p-5 text-white">
      <div class="flex items-start justify-between">
        <div>
          <div class="text-sm font-semibold opacity-90">Active Users</div>
          <div class="text-3xl font-bold mt-2"><%= stats.activeUsers %></div>
        </div>
        <div class="p-3 bg-white/15 rounded-xl">
          <svg class="h-6 w-6 opacity-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      <div class="text-xs opacity-75 mt-3">Status = active</div>
    </div>

    <div class="bg-gradient-to-br from-violet-600 to-purple-700 rounded-xl shadow-lg p-5 text-white">
      <div class="flex items-start justify-between">
        <div>
          <div class="text-sm font-semibold opacity-90">Admin Users</div>
          <div class="text-3xl font-bold mt-2"><%= stats.adminUsers %></div>
        </div>
        <div class="p-3 bg-white/15 rounded-xl">
          <svg class="h-6 w-6 opacity-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c2.21 0 4-1.79 4-4S14.21 3 12 3 8 4.79 8 7s1.79 4 4 4zm0 2c-3.87 0-7 2.13-7 5v1h14v-1c0-2.87-3.13-5-7-5z" />
          </svg>
        </div>
      </div>
      <div class="text-xs opacity-75 mt-3">Role = admin</div>
    </div>

    <div class="bg-gradient-to-br from-amber-500 to-orange-600 rounded-xl shadow-lg p-5 text-white">
      <div class="flex items-start justify-between">
        <div>
          <div class="text-sm font-semibold opacity-90">Total Purchases</div>
          <div class="text-3xl font-bold mt-2"><%= stats.totalPurchases.toLocaleString() %></div>
        </div>
        <div class="p-3 bg-white/15 rounded-xl">
          <svg class="h-6 w-6 opacity-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
        </div>
      </div>
      <div class="text-xs opacity-75 mt-3"><%= stats.completedPurchases.toLocaleString() %> completed</div>
    </div>

    <div class="bg-gradient-to-br from-cyan-600 to-blue-700 rounded-xl shadow-lg p-5 text-white">
      <div class="flex items-start justify-between">
        <div>
          <div class="text-sm font-semibold opacity-90">Revenue (MMK)</div>
          <div class="text-2xl font-bold mt-2"><%= stats.totalRevenueMMK.toLocaleString() %></div>
        </div>
        <div class="p-3 bg-white/15 rounded-xl">
          <svg class="h-6 w-6 opacity-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>
      <div class="text-xs opacity-75 mt-3">Total earnings</div>
    </div>

    <!-- G2Bulk Account Card -->
    <div class="bg-gradient-to-br from-orange-500 to-orange-600 rounded-xl shadow-lg p-5 text-white">
      <div class="flex items-start justify-between">
        <div>
          <div class="text-sm font-semibold opacity-90">G2Bulk Account</div>
          <% if (g2bulk && g2bulk.ok && g2bulk.data) { %>
             <div class="text-2xl font-bold mt-2"><%= (typeof g2bulk.data.balance !== 'undefined') ? Number(g2bulk.data.balance).toFixed(2) : '-' %></div>
          <% } else { %>
             <div class="text-lg font-bold mt-2 text-red-200">Unavailable</div>
          <% } %>
        </div>
        <div class="p-3 bg-white/15 rounded-xl">
           <svg class="h-6 w-6 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
           </svg>
        </div>
      </div>
      <div class="text-xs opacity-75 mt-3">
         <% if (g2bulk && g2bulk.ok && g2bulk.data) { %>
            User ID: <%= g2bulk.data.user_id || '-' %> | <%= g2bulk.data.username || '-' %>
         <% } else { %>
            <%= (g2bulk && g2bulk.error) ? g2bulk.error : 'Not configured' %>
         <% } %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 mb-6">
    <div class="bg-white/5 border border-white/10 rounded-xl shadow-lg overflow-hidden">
      <div class="px-5 py-4 flex items-center justify-between border-b border-white/10">
        <div class="text-sm font-bold text-white">Recent Purchases</div>
        <a href="/admin/game-purchase-transactions" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-gradient-to-r from-amber-400 to-orange-500 text-white text-xs font-semibold shadow-md hover:opacity-95 transition-opacity">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          View Purchases
        </a>
      </div>
      <div class="p-5">
        <% if (stats.recentPurchases && stats.recentPurchases.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="text-xs uppercase text-gray-300">
                <tr class="bg-white/5">
                  <th class="text-left font-semibold px-3 py-3">Product</th>
                  <th class="text-left font-semibold px-3 py-3">User</th>
                  <th class="text-right font-semibold px-3 py-3">Amount</th>
                  <th class="text-left font-semibold px-3 py-3">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/10">
                <% stats.recentPurchases.forEach(function(purchase) { %>
                  <tr class="hover:bg-white/5 transition-colors">
                    <td class="px-3 py-3">
                      <div class="font-medium text-white"><%= purchase.Product ? purchase.Product.name : purchase.product_name %></div>
                      <div class="text-xs text-gray-400"><%= purchase.Product ? purchase.Product.category : '' %></div>
                    </td>
                    <td class="px-3 py-3 text-gray-300"><%= purchase.User ? purchase.User.name : purchase.user_name %></td>
                    <td class="px-3 py-3 text-right font-medium text-gray-200">
                      <%= parseFloat(purchase.total_amount).toLocaleString() %> <%= purchase.currency %>
                    </td>
                    <td class="px-3 py-3">
                      <% const isG2BulkPending = purchase.provider === 'g2bulk' && purchase.status === 'pending'; %>
                      <% const isG2BulkProcessing = purchase.provider === 'g2bulk' && purchase.status === 'processing'; %>
                      <% const isG2BulkCompleted = purchase.provider === 'g2bulk' && (purchase.status === 'completed' || purchase.status === 'success'); %>
                      <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-semibold <%= (isG2BulkPending || isG2BulkProcessing || isG2BulkCompleted || ['completed', 'success', 'partial_success'].includes(purchase.status)) ? 'bg-emerald-600/25 text-emerald-200 border border-emerald-500/30' : (purchase.status === 'pending' || purchase.status === 'processing' ? 'bg-amber-600/25 text-amber-200 border border-amber-500/30' : 'bg-red-600/25 text-red-200 border border-red-500/30') %>">
                        <% if (isG2BulkPending) { %>
                          success (p)
                        <% } else if (isG2BulkProcessing) { %>
                          success (n)
                        <% } else if (isG2BulkCompleted) { %>
                          success
                        <% } else { %>
                          <%= purchase.status %>
                        <% } %>
                      </span>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="py-10 text-center">
            <div class="text-gray-300 font-semibold">No purchases yet</div>
            <div class="text-xs text-gray-400 mt-2">New purchases will appear here.</div>
          </div>
        <% } %>
      </div>
    </div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white/5 border border-white/10 rounded-xl shadow-lg overflow-hidden">
      <div class="px-5 py-4 flex items-center justify-between border-b border-white/10">
        <div class="text-sm font-bold text-white">Recent Users</div>
        <a href="/admin/users" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-gradient-to-r from-blue-600 to-purple-600 text-white text-xs font-semibold shadow-md hover:opacity-95 transition-opacity">
          View All
        </a>
      </div>
      <div class="p-5">
        <% if (stats.recentUsers && stats.recentUsers.length > 0) { %>
          <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="text-xs uppercase text-gray-300">
                <tr class="bg-white/5">
                  <th class="text-left font-semibold px-3 py-3">Name</th>
                  <th class="text-left font-semibold px-3 py-3">Email</th>
                  <th class="text-left font-semibold px-3 py-3">Role</th>
                  <th class="text-left font-semibold px-3 py-3">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/10">
                <% stats.recentUsers.forEach(function(recentUser) { %>
                  <tr class="hover:bg-white/5 transition-colors">
                    <td class="px-3 py-3 font-medium text-white"><%= recentUser.name %></td>
                    <td class="px-3 py-3 text-gray-300"><%= recentUser.email %></td>
                    <td class="px-3 py-3">
                      <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-semibold <%= recentUser.role === 'admin' ? 'bg-red-600/25 text-red-200 border border-red-500/30' : 'bg-blue-600/25 text-blue-200 border border-blue-500/30' %>">
                        <%= recentUser.role %>
                      </span>
                    </td>
                    <td class="px-3 py-3">
                      <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-semibold <%= recentUser.status === 'active' ? 'bg-emerald-600/25 text-emerald-200 border border-emerald-500/30' : 'bg-amber-600/25 text-amber-200 border border-amber-500/30' %>">
                        <%= recentUser.status %>
                      </span>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="py-10 text-center">
            <div class="text-gray-300 font-semibold">No users found</div>
            <div class="text-xs text-gray-400 mt-2">New users will appear here.</div>
          </div>
        <% } %>
      </div>
    </div>

    <div class="space-y-6">
      <div class="bg-white/5 border border-white/10 rounded-xl shadow-lg overflow-hidden">
        <div class="px-5 py-4 border-b border-white/10">
          <div class="text-sm font-bold text-white">Quick Actions</div>
        </div>
        <div class="p-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/admin/users" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 text-white font-semibold shadow-md hover:opacity-95 transition-opacity">
              <i class="fas fa-users"></i>
              Manage Users
            </a>
            <a href="/admin/wallets" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-gradient-to-r from-amber-500 to-orange-600 text-white font-semibold shadow-md hover:opacity-95 transition-opacity">
              <i class="fas fa-wallet"></i>
              Manage Wallets
            </a>
            <a href="/admin/transactions" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-gradient-to-r from-cyan-600 to-blue-700 text-white font-semibold shadow-md hover:opacity-95 transition-opacity">
              <i class="fas fa-credit-card"></i>
              Transactions
            </a>
            <a href="/admin/settings" class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-white/10 hover:bg-white/15 border border-white/10 text-white font-semibold shadow-md transition-colors">
              <i class="fas fa-cog"></i>
              Settings
            </a>
          </div>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl shadow-lg overflow-hidden">
        <div class="px-5 py-4 border-b border-white/10">
          <div class="text-sm font-bold text-white">System Information</div>
        </div>
        <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          <div class="bg-white/5 border border-white/10 rounded-lg p-4">
            <div class="text-gray-300">Version</div>
            <div class="text-white font-semibold mt-1">1.0.0</div>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-lg p-4">
            <div class="text-gray-300">Environment</div>
            <div class="text-white font-semibold mt-1">Development</div>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-lg p-4">
            <div class="text-gray-300">Database</div>
            <div class="text-white font-semibold mt-1">MySQL</div>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-lg p-4">
            <div class="text-gray-300">Server</div>
            <div class="text-white font-semibold mt-1">Node.js</div>
          </div>
        </div>
      </div>
    </div>
  </div>

<!-- Error Display -->
<% if (typeof error !=='undefined' && error) { %>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      showErrorToast('<%= error %>');
    });
  </script>
<% } %>
