<%- contentFor('body') %>

<!-- Page Heading with improved styling -->
<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="h3 mb-0 text-gray-800">
      <i class="fas fa-chart-line text-primary mr-2"></i>
      Reports & Analytics
    </h1>
    <p class="text-muted mb-0">Comprehensive insights into your business performance</p>
  </div>

  <div class="d-flex align-items-center">
    <!-- Date Range Selection -->
    <div class="mr-3">
      <button class="btn btn-outline-primary btn-sm" type="button" id="toggleDateRangeBtn">
        <i class="fas fa-calendar-alt"></i> Custom Date Range
      </button>
    </div>

    <!-- Period Filter -->
    <div class="mr-3">
      <form method="GET" action="/admin/reports" style="display: inline;">
        <select name="period" class="form-control form-control-sm" onchange="this.form.submit()" style="width: auto; min-width: 140px;">
          <option value="7" <%=period=='7' ? 'selected' : '' %>>Last 7 Days</option>
          <option value="30" <%=period=='30' ? 'selected' : '' %>>Last 30 Days</option>
          <option value="90" <%=period=='90' ? 'selected' : '' %>>Last 90 Days</option>
          <option value="365" <%=period=='365' ? 'selected' : '' %>>Last Year</option>
        </select>
      </form>
    </div>

    <button class="btn btn-primary btn-sm" onclick="window.print()">
      <i class="fas fa-print fa-sm"></i> Print Report
    </button>
  </div>
</div>

<!-- Custom Date Range Collapse with improved styling -->
<div class="mb-4" id="dateRangeCollapse" style="display: none;">
  <div class="card card-body border-primary" style="background-color: #1e293b !important; color: #fff;">
    <div class="row">
      <div class="col-12 mb-3">
        <h6 class="text-primary mb-2">
          <i class="fas fa-clock"></i> Quick Presets
        </h6>
        <div class="btn-group btn-group-sm" role="group">
          <a href="/admin/reports?range=today" class="btn btn-outline-secondary">
            <i class="fas fa-calendar-day"></i> Today
          </a>
          <a href="/admin/reports?range=yesterday" class="btn btn-outline-secondary">
            <i class="fas fa-calendar-minus"></i> Yesterday
          </a>
          <a href="/admin/reports?range=this_week" class="btn btn-outline-secondary">
            <i class="fas fa-calendar-week"></i> This Week
          </a>
          <a href="/admin/reports?range=last_week" class="btn btn-outline-secondary">
            <i class="fas fa-calendar-week"></i> Last Week
          </a>
          <a href="/admin/reports?range=this_month" class="btn btn-outline-secondary">
            <i class="fas fa-calendar-alt"></i> This Month
          </a>
          <a href="/admin/reports?range=last_month" class="btn btn-outline-secondary">
            <i class="fas fa-calendar-alt"></i> Last Month
          </a>
        </div>
      </div>
    </div>

    <form method="GET" action="/admin/reports">
      <div class="row">
        <div class="col-md-4">
          <label for="startDate" class="form-label">
            <i class="fas fa-calendar-plus text-success"></i> Start Date
          </label>
          <input type="date" name="startDate" id="startDate" class="form-control" value="<%= startDate %>">
        </div>
        <div class="col-md-4">
          <label for="endDate" class="form-label">
            <i class="fas fa-calendar-minus text-danger"></i> End Date
          </label>
          <input type="date" name="endDate" id="endDate" class="form-control" value="<%= endDate %>">
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <button type="submit" class="btn btn-success btn-sm w-100">
            <i class="fas fa-search"></i> Apply Date Range
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Current Date Range Display with improved styling -->
<div class="alert alert-info mb-4 border-left-primary">
  <div class="d-flex align-items-center">
    <i class="fas fa-info-circle fa-2x text-primary mr-3"></i>
    <div>
      <strong>Current Date Range:</strong>
      <span id="currentDateRange" class="badge badge-primary ml-2">
        <% if (startDate && endDate) { %>
        <%= new Date(startDate).toLocaleDateString() %> to <%= new Date(endDate).toLocaleDateString() %>
        <% } else { %>
        Last <%= period %> days
        <% } %>
      </span>
      <br>
      <small class="text-muted">Data is filtered based on the selected period</small>
    </div>
  </div>
</div>

<% if (typeof error !=='undefined' && error) { %>
<div class="alert alert-danger border-left-danger" role="alert">
  <div class="d-flex align-items-center">
    <i class="fas fa-exclamation-triangle fa-2x text-danger mr-3"></i>
    <div>
      <strong>Error:</strong>
      <%= error %>
    </div>
  </div>
</div>
<% } %>



<!-- Main content container -->
<div id="reportContent">

  <!-- Statistics Cards Row -->
  <div class="row">

    <!-- Users Card -->
    <div class="col-xl-3 col-md-6 mb-4">
      <div class="card border-left-primary shadow h-100 py-2">
