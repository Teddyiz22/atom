<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="h3 mb-0 text-gray-800">
      <i class="fas fa-receipt text-primary mr-2"></i>
      Game Purchase Transactions
    </h1>
    <p class="text-muted mb-0">Provider purchase transaction logs</p>
  </div>
  <a href="/admin" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
    <i class="fas fa-arrow-left fa-sm text-white-50"></i> Back to Dashboard
  </a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger">
    <i class="fas fa-exclamation-triangle mr-2"></i>
    <%= error %>
  </div>
<% } %>

<style>
  /* Fix DataTables length menu visibility */
  .dataTables_length select {
    background-color: #fff !important;
    color: #6e707e !important;
    border: 1px solid #d1d3e2 !important;
    border-radius: 0.35rem;
    padding: 0.375rem 1.75rem 0.375rem 0.75rem;
    display: inline-block;
    width: auto;
  }
    .dataTables_length select {
      width: 6rem !important;          
      min-width: 6rem !important;      
      padding: 0.375rem 0.75rem !important; 
      border-radius: 0.35rem !important;    
      border: 1px solid #d1d3e2 !important; 
      background-color: #fff !important;   
      color: #6e707e !important;          
      display: inline-block !important;
    }
</style>

<div class="card shadow mb-4">
  <div class="card-header py-3 d-flex align-items-center justify-content-between">
    <h6 class="m-0 font-weight-bold text-primary">Recent Transactions</h6>
  </div>
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-bordered table-hover" id="transactionsTable">
        <thead class="thead-light">
          <tr>
            <th>ID</th>
            <th>User</th>
            <th>Game ID</th>
            <th>Server ID</th>
            <th>Provider</th>
            <th>Type Code</th>
            <th>Product</th>
            <th class="text-right">Total</th>
            <th>Status</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          <!-- Data will be loaded via AJAX -->
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Check if jQuery is loaded, if not wait for it
    function initializeDataTable() {
      if (typeof $ !== 'undefined' && typeof $.fn.DataTable !== 'undefined') {
        $('#transactionsTable').DataTable({
          "processing": true,
          "serverSide": true,
          "ajax": {
            "url": "/admin/game-purchase-transactions/data",
            "type": "GET"
          },
          "columns": [
            { "data": 0 }, // ID
            { "data": 1 }, // User
            { "data": 2 }, // Game ID
            { "data": 3 }, // Server ID
            { "data": 4 }, // Provider
            { "data": 5 }, // Type Code
            { "data": 6 }, // Product
            { "data": 7 }, // Total
            { "data": 8 }, // Status
            { "data": 9 }  // Created
          ],
          "order": [[9, "desc"]], // Sort by Created (index 9) descending
          "pageLength": 25,
          "lengthMenu": [
            [10, 25, 50, 100],
            [10, 25, 50, 100]
          ],
          "language": {
            "search": "Search transactions:",
            "lengthMenu": "Show _MENU_ transactions per page",
            "info": "Showing _START_ to _END_ of _TOTAL_ transactions",
            "infoFiltered": "(filtered from _MAX_ total transactions)",
            "emptyTable": "No transactions found",
            "zeroRecords": "No matching transactions found",
            "processing": "Loading transactions..."
          },
          "responsive": true
        });
      } else {
        setTimeout(initializeDataTable, 100);
      }
    }

    initializeDataTable();
  });
</script>
