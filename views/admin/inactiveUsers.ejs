<!-- Page Heading -->
<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <h1 class="h3 mb-0 text-gray-800">Inactive Users (3 months+ / Never)</h1>

  <!-- Button Group -->
  <div class="btn-group" role="group">
    <a href="/admin/users" class="btn btn-sm btn-primary shadow-sm">
      <i class="fas fa-arrow-left fa-sm text-white-50"></i> Back to Users
    </a>
  </div>
</div>

<style>
  .dataTables_length select {
    background-color: #fff !important;
    color: #6e707e !important;
    border: 1px solid #d1d3e2 !important;
    border-radius: 0.35rem;
    padding: 0.375rem 1.75rem 0.375rem 0.75rem;
    display: inline-block;
    width: auto;
  }
</style>

<div class="card shadow mb-4">
  <div class="card-header py-3 d-flex justify-content-between align-items-center">
    <h6 class="m-0 font-weight-bold text-danger">
      <i class="fas fa-user-slash mr-2"></i>
      Total <strong><%= totalInactiveUser %></strong> Inactive Users
    </h6>
  </div>

  <div class="card-body">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="table-responsive">
      <table class="table table-bordered" id="inactiveUsersTable" width="100%" cellspacing="0">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Email Verified</th>
            <th>Last Login</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    function initializeDataTable() {
      if (typeof $ !== 'undefined' && typeof $.fn.DataTable !== 'undefined') {
        $('#inactiveUsersTable').DataTable({
          processing: true,
          serverSide: true,
          ajax: {
            url: '/admin/users/inactiveuserlist/data',
            type: 'GET'
          },
          columns: [
            { data: 0 }, // ID
            { data: 1 }, // Name
            { data: 2 }, // Email
            { data: 3 }, // Phone
            { data: 4 }, // Status
            { data: 5 }, // Email Verified
            { data: 6 }, // Last Login (badge)
            { data: 7 }, // Created
            { data: 8, orderable: false, searchable: false } // Actions
          ],
          order: [[0, 'desc']],
          pageLength: 25,
          lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
          language: {
            search: 'Search users:',
            lengthMenu: 'Show _MENU_ users per page',
            info: 'Showing _START_ to _END_ of _TOTAL_ users',
            infoFiltered: '(filtered from _MAX_ total users)',
            emptyTable: 'No inactive users found',
            zeroRecords: 'No matching users found',
            processing: 'Loading users...'
          },
          responsive: true
        });
      } else {
        setTimeout(initializeDataTable, 100);
      }
    }

    initializeDataTable();
  });

  // Reuse existing admin/users toggle endpoint
  function toggleUserStatus(userId) {
    fetch(`/admin/users/${userId}/toggle-status`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          $('#inactiveUsersTable').DataTable().ajax.reload(null, false);
          alert('Success: ' + data.message);
        } else {
          alert('Error: ' + (data.error || 'Failed to update user status'));
        }
      })
      .catch(() => alert('An error occurred while updating user status'));
  }
</script>

