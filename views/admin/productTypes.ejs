<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="h3 mb-0 text-gray-800">
      <i class="fas fa-tags text-primary mr-2"></i>
      Product Types
    </h1>
    <p class="text-muted mb-0">Manage provider product type codes</p>
  </div>
  <a href="/admin" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
    <i class="fas fa-arrow-left fa-sm text-white-50"></i> Back to Dashboard
  </a>
</div>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success">
    <i class="fas fa-check-circle mr-2"></i>
    Saved.
  </div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger">
    <i class="fas fa-exclamation-triangle mr-2"></i>
    <%= error %>
  </div>
<% } %>

<div class="row">
  <div class="col-lg-5">
    <div class="card shadow mb-4">
      <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Add / Update</h6>
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/product-types/save">
          <input type="hidden" name="id" value="<%= form?.id || '' %>">

          <div class="form-group">
            <label for="provider">Provider</label>
            <select class="form-control" id="provider" name="provider" required>
              <option value="smile" <%= form?.provider === 'smile' ? 'selected' : '' %>>smile</option>
              <option value="g2bulk" <%= form?.provider === 'g2bulk' ? 'selected' : '' %>>g2bulk</option>
            </select>
          </div>

          <div class="form-group">
            <label for="type_code">Type Code</label>
            <input type="text" class="form-control" id="type_code" name="type_code" required value="<%= form?.type_code || '' %>">
          </div>

          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" class="form-control" id="name" name="name" required value="<%= form?.name || '' %>">
          </div>

          <div class="form-group">
            <label for="status">Status</label>
            <select class="form-control" id="status" name="status" required>
              <option value="active" <%= (form?.status || 'active') === 'active' ? 'selected' : '' %>>active</option>
              <option value="inactive" <%= form?.status === 'inactive' ? 'selected' : '' %>>inactive</option>
            </select>
          </div>

          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save mr-2"></i>
            Save
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-7">
    <div class="card shadow mb-4">
      <div class="card-header py-3 d-flex align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">All Product Types</h6>
        <span class="small text-muted"><%= productTypes?.length || 0 %> records</span>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead class="thead-light">
              <tr>
                <th>ID</th>
                <th>Provider</th>
                <th>Type Code</th>
                <th>Name</th>
                <th>Status</th>
                <th style="width: 90px;"></th>
              </tr>
            </thead>
            <tbody>
              <% if (!productTypes || productTypes.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center text-muted">No product types yet.</td>
                </tr>
              <% } else { %>
                <% productTypes.forEach(pt => { %>
                  <tr>
                    <td><%= pt.id %></td>
                    <td><%= pt.provider %></td>
                    <td><%= pt.typeCode %></td>
                    <td><%= pt.name %></td>
                    <td>
                      <span class="badge badge-<%= pt.status === 'active' ? 'success' : 'secondary' %>">
                        <%= pt.status %>
                      </span>
                    </td>
                    <td class="text-center">
                      <form method="POST" action="/admin/product-types/toggle" class="d-inline-block m-0">
                        <input type="hidden" name="id" value="<%= pt.id %>">
                        <button type="submit" class="btn btn-sm btn-<%= pt.status === 'active' ? 'warning' : 'success' %> mr-1" title="<%= pt.status === 'active' ? 'Deactivate' : 'Activate' %>">
                          <i class="fas fa-<%= pt.status === 'active' ? 'ban' : 'check' %>"></i>
                        </button>
                      </form>
                      <form method="POST" action="/admin/product-types/delete" class="d-inline-block m-0" onsubmit="return confirm('Delete this product type?')">
                        <input type="hidden" name="id" value="<%= pt.id %>">
                        <button type="submit" class="btn btn-sm btn-danger">
                          <i class="fas fa-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
