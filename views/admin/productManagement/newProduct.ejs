<%
  const isEdit = typeof editingProduct !== 'undefined' && editingProduct && editingProduct.id;
  const backToListUrl = `/admin/product-management/${encodeURIComponent(provider)}/${encodeURIComponent(productType.typeCode)}`;
  const submitUrl = isEdit
    ? `/admin/product-management/${encodeURIComponent(provider)}/${encodeURIComponent(productType.typeCode)}/edit/${encodeURIComponent(editingProduct.id)}`
    : `/admin/product-management/${encodeURIComponent(provider)}/${encodeURIComponent(productType.typeCode)}/new`;
  const f = (typeof form !== 'undefined' && form) ? form : {};
  const v = (key, fallback = '') => (f[key] !== undefined ? f[key] : fallback);
%>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-start justify-between gap-4 border-b border-white/10 pb-5 mb-8">
    <div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">
        <%= isEdit ? 'Edit' : 'Add' %>
        <span class="<%= provider === 'smile' ? 'text-indigo-300' : (provider === 'manual' ? 'text-amber-300' : 'text-teal-300') %>"><%= provider %></span>
        Product
        <span class="text-gray-200">- <%= productType.name %></span>
      </h1>
      <p class="text-sm text-gray-300 mt-2">Type Code: <span class="font-mono text-gray-200"><%= productType.typeCode %></span></p>
    </div>
    <a href="<%= backToListUrl %>" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-sm font-semibold text-gray-100 transition-colors">
      <svg class="h-4 w-4 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back
    </a>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-red-200">
      <%= error %>
    </div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 rounded-2xl border border-white/10 bg-white/5 p-6">
      <form method="POST" action="<%= submitUrl %>" class="space-y-5">
        <div>
          <label for="name" class="block text-sm font-semibold text-gray-200 mb-2">Name</label>
          <input type="text" id="name" name="name" required value="<%= v('name') %>" class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-2 text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500/50">
        </div>

        <div>
          <label class="flex items-center space-x-2 text-sm font-semibold text-gray-200 mb-2 cursor-pointer bg-white/5 p-3 rounded-lg border border-white/10 hover:bg-white/10 transition-colors">
            <input type="checkbox" name="is_featured" class="form-checkbox rounded bg-gray-700 border-gray-600 text-indigo-500 focus:ring-indigo-500 h-5 w-5" <%= (v('is_featured') || (typeof editingProduct !== 'undefined' && editingProduct.is_featured)) ? 'checked' : '' %>>
            <span class="select-none">✨ Featured Product (Show at top)</span>
          </label>
        </div>

        <% if (provider === 'smile' || provider === 'manual') { %>
          <div>
            <label for="region" class="block text-sm font-semibold text-gray-200 mb-2">Region</label>
            <select id="region" name="region" required class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-2 text-gray-100 focus:outline-none focus:ring-2 focus:ring-brand-500/50">
              <option value="b" <%= (v('region', 'b') === 'b') ? 'selected' : '' %>>Brazil</option>
              <option value="ph" <%= (v('region') === 'ph') ? 'selected' : '' %>>Philippines</option>
            </select>
          </div>
        <% } %>

        <div>
          <label for="diamond_amount" class="block text-sm font-semibold text-gray-200 mb-2"><%= (provider === 'smile' || provider === 'manual') ? 'Amount / display value' : 'USD Amount' %></label>
          <input type="number" id="diamond_amount" name="diamond_amount" min="0" step="<%= (provider === 'smile' || provider === 'manual') ? '0.01' : '1' %>" required value="<%= v('diamond_amount') %>" class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-2 text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500/50">
        </div>

        <!-- Price inputs for all providers -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="price_mmk" class="block text-sm font-semibold text-gray-200 mb-2">Price (MMK)</label>
            <input type="number" id="price_mmk" name="price_mmk" min="0" step="0.01" required value="<%= v('price_mmk') %>" class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-2 text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500/50">
          </div>
          <div>
            <label for="price_thb" class="block text-sm font-semibold text-gray-200 mb-2">Price (THB)</label>
            <input type="number" id="price_thb" name="price_thb" min="0" step="0.01" required value="<%= v('price_thb') %>" class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-2 text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500/50">
          </div>
        </div>

        <% if (provider === 'smile') { %>
          <div>
            <label for="category" class="block text-sm font-semibold text-gray-200 mb-2">Category</label>
            <select id="category" name="category" class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-2 text-gray-100 focus:outline-none focus:ring-2 focus:ring-brand-500/50">
              <option value="DIAMOND" <%= (v('category', 'DIAMOND') === 'DIAMOND') ? 'selected' : '' %>>DIAMOND</option>
              <option value="WEEKLY_PASS" <%= (v('category') === 'WEEKLY_PASS') ? 'selected' : '' %>>WEEKLY_PASS</option>
              <option value="TWILIGHT_PASS" <%= (v('category') === 'TWILIGHT_PASS') ? 'selected' : '' %>>TWILIGHT_PASS</option>
              <option value="DOUBLE_DIAMOND" <%= (v('category') === 'DOUBLE_DIAMOND') ? 'selected' : '' %>>DOUBLE_DIAMOND</option>
            </select>
          </div>
          <div>
            <label for="smile_id_combination" class="block text-sm font-semibold text-gray-200 mb-2">Smile ID Combination</label>
            <input type="text" id="smile_id_combination" name="smile_id_combination" value="<%= v('smile_id_combination') %>" class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-2 text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500/50">
          </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="status" class="block text-sm font-semibold text-gray-200 mb-2">Status</label>
            <select id="status" name="status" required class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-2 text-gray-100 focus:outline-none focus:ring-2 focus:ring-brand-500/50">
              <option value="active" <%= (v('status', 'active') === 'active') ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= (v('status') === 'inactive') ? 'selected' : '' %>>Inactive</option>
            </select>
          </div>
          <div>
            <label for="sort_order" class="block text-sm font-semibold text-gray-200 mb-2">Sort Order</label>
            <input type="number" id="sort_order" name="sort_order" min="0" step="1" value="<%= v('sort_order', '0') %>" class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-2 text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500/50">
          </div>
        </div>

        <div class="flex flex-wrap gap-2 pt-2">
          <button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg <%= (provider === 'smile' || provider === 'manual') ? 'bg-indigo-600 hover:bg-indigo-500' : 'bg-teal-600 hover:bg-teal-500' %> text-sm font-semibold text-white transition-colors">
            <%= isEdit ? 'Save' : 'Add' %>
            <i class="fas fa-save text-xs"></i>
          </button>
          <a href="<%= backToListUrl %>" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-sm font-semibold text-gray-100 transition-colors">
            Cancel
          </a>
        </div>
      </form>
    </div>

    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <div class="text-sm font-semibold text-white mb-4">Details</div>
      <div class="space-y-3">
        <div>
          <div class="text-xs font-semibold uppercase text-gray-400">Provider</div>
          <div class="text-sm font-bold text-gray-100"><%= provider %></div>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase text-gray-400">Type Code</div>
          <div class="text-sm font-bold text-gray-100 font-mono"><%= productType.typeCode %></div>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase text-gray-400">Type</div>
          <div class="text-sm font-bold text-gray-100"><%= productType.type %></div>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase text-gray-400">Type Status</div>
          <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold uppercase <%= productType.status === 'active' ? 'bg-emerald-500/15 text-emerald-200 border border-emerald-400/20' : 'bg-white/10 text-gray-200 border border-white/10' %>">
            <%= productType.status %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
