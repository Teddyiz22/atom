<!-- Page Heading -->
<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <h1 class="h3 mb-0 text-gray-800">Unverified Users</h1>

  <!-- Button Group -->
  <div class="btn-group" role="group">
    <a href="/admin/users" class="btn btn-sm btn-primary shadow-sm">
      <i class="fas fa-arrow-left fa-sm text-white-50"></i> Back to Users
    </a>
  </div>
</div>

<style>
  /* Fix DataTables length menu visibility */
  .dataTables_length select {
    background-color: #fff !important;
    color: #6e707e !important; /* SB Admin 2 text color */
    border: 1px solid #d1d3e2 !important;
    border-radius: 0.35rem;
    padding: 0.375rem 1.75rem 0.375rem 0.75rem;
    display: inline-block;
    width: auto;
  }
</style>

<div class="card shadow mb-4">
  <div class="card-header py-3 d-flex justify-content-between align-items-center">
    <h6 class="m-0 font-weight-bold text-danger">
      <i class="fas fa-user-times mr-2"></i>
      Total <strong><%= totalUnverifiedUser %></strong> Unverified Users
    </h6>

    <button class="btn btn-sm btn-success shadow-sm" onclick="approveAll(<%= totalUnverifiedUser %>)" <%= totalUnverifiedUser === 0 ? 'disabled' : '' %>>
      <i class="fas fa-user-check mr-1"></i>
      Approve All
    </button>

  </div>

  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-bordered" id="usersTable" width="100%" cellspacing="0">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Email Verified</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>

        </tbody>
      </table>
    </div>

  </div>

</div>

<script>
  function approveAll(totalUnverifiedUser) {
    if (!confirm(`Are you sure you want to approve all ${totalUnverifiedUser} unverified users?`)) {
      return;
    }

    fetch('/admin/users/approve-all', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          alert('All users approved successfully!');
          location.reload();
        } else {
          alert('Something went wrong!');
        }
      })
      .catch(err => {
        console.error(err);
        alert('Server error!');
      });
  }

  function verifyUser(id) {
    fetch(`/admin/users/${id}/verify`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          $('#usersTable').DataTable().ajax.reload(null, false);
          alert(`User ID (${id})  verified successfully!`);
          location.reload();
        } else {
          alert(data.error || 'Failed to verify user');
        }
      })
      .catch(err => {
        console.error(err);
        alert('Server error');
      });
  }
  document.addEventListener('DOMContentLoaded', function() {

    // Check if jQuery is loaded, if not wait for it
    function initializeDataTable() {
      if (typeof $ !== 'undefined' && typeof $.fn.DataTable !== 'undefined') {
        // Initialize DataTables with server-side processing
        $('#usersTable').DataTable({
          "processing": true,
          "serverSide": true,
          "ajax": {
            "url": "/admin/users/unverifiedList/data",
            "type": "GET"
          },
          "columns": [{
              "data": 0
            }, // ID
            {
              "data": 1
            }, // Name
            {
              "data": 2
            }, // Email
            {
              "data": 3
            }, // Phone
            {
              "data": 4
            }, // Status
            {
              "data": 5
            }, // Email Verified
            {
              "data": 6
            }, // Created
            {
              "data": 7
            } // Actions
          ],
          "order": [
            [0, "desc"]
          ], // Sort by ID descending (newest first)
          "pageLength": 25,
          "lengthMenu": [
            [10, 25, 50, 100],
            [10, 25, 50, 100]
          ],
          "language": {
            "search": "Search users:",
            "lengthMenu": "Show _MENU_ users per page",
            "info": "Showing _START_ to _END_ of _TOTAL_ users",
            "infoFiltered": "(filtered from _MAX_ total users)",
            "emptyTable": "No users found",
            "zeroRecords": "No matching users found",
            "processing": "Loading users..."
          },
          "responsive": true
        });
      } else {
        // jQuery or DataTables not loaded yet, wait and try again
        setTimeout(initializeDataTable, 100);
      }
    }

    // Start initialization
    initializeDataTable();
  });
</script>