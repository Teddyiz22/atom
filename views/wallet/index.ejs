<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: 'Wallet - ATOM Game Shop' ,
    description: 'Top up your ATOM Game Shop wallet with multiple payment methods. Fast and secure transactions.' }) %>
</head>

<body class="bg-gray-50 font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>

    <!-- Wallet Section -->
    <section class="relative min-h-screen pt-20 pb-16">
      <!-- Modern Gradient Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
      </div>

      <!-- Content -->
      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="text-center mb-8 animate-fade-in">
          <h1
            class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent mb-4">
            💰 My Wallet
          </h1>
          <p class="text-lg text-gray-300 max-w-2xl mx-auto">
            Manage your ML Diamonds wallet balance and top up securely
          </p>
        </div>

        <!-- Wallet Balance Cards -->
        <div class="grid sm:grid-cols-2 gap-6 mb-8 animate-slide-up">
          <!-- MMK Balance -->
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20 relative overflow-hidden">
            <div
              class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-theme-400/20 to-theme-600/20 rounded-full transform translate-x-16 -translate-y-16">
            </div>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-white">Myanmar Kyat</h3>
                <span class="text-2xl">🇲🇲</span>
              </div>
              <div class="mb-6">
                <p class="text-3xl font-bold text-theme-300 mb-2">
                  <%= new Intl.NumberFormat('en-US').format(wallet.mmk_balance || 0) %>
                    <span class="text-lg text-gray-300">MMK</span>
                </p>
                <p class="text-sm text-gray-400">Available Balance</p>
              </div>
              <a href="/wallet/topup?currency=MMK"
                class="w-full bg-gradient-to-r from-theme-500 to-theme-600 hover:from-theme-600 hover:to-theme-700 text-white font-medium py-3 px-4 rounded-lg transition-all duration-300 transform hover:scale-105 block text-center">
                Top Up MMK →
              </a>
            </div>
          </div>

          <!-- THB Balance -->
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20 relative overflow-hidden">
            <div
              class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-theme-400/20 to-theme-600/20 rounded-full transform translate-x-16 -translate-y-16">
            </div>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-white">Thai Baht</h3>
                <span class="text-2xl">🇹🇭</span>
              </div>
              <div class="mb-6">
                <p class="text-3xl font-bold text-theme-300 mb-2">
                  ฿<%= new Intl.NumberFormat('en-US').format(wallet.thb_balance || 0) %>
                    <span class="text-lg text-gray-300">BAHT</span>
                </p>
                <p class="text-sm text-gray-400">Available Balance</p>
              </div>
              <a href="/wallet/topup?currency=THB"
                class="w-full bg-gradient-to-r from-theme-500 to-theme-600 hover:from-theme-600 hover:to-theme-700 text-white font-medium py-3 px-4 rounded-lg transition-all duration-300 transform hover:scale-105 block text-center">
                Top Up THB →
              </a>
            </div>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 md:p-8 border border-white/20 mb-8 animate-slide-up">
          <h3 class="text-xl md:text-2xl font-bold text-white mb-6">Quick Actions</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <a href="/wallet/topup"
              class="flex items-center justify-center bg-gradient-to-r from-green-500 to-green-600 text-white px-6 py-4 rounded-xl hover:from-green-600 hover:to-green-700 transition-all transform hover:scale-105">
              <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
              </svg>
              <span class="font-semibold">Top Up Wallet</span>
            </a>
            <a href="/profile"
              class="flex items-center justify-center bg-gradient-to-r from-blue-500 to-blue-600 text-white px-6 py-4 rounded-xl hover:from-blue-600 hover:to-blue-700 transition-all transform hover:scale-105">
              <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span class="font-semibold">Transaction History</span>
            </a>
            <a href="/shop"
              class="flex items-center justify-center bg-gradient-to-r from-theme-500 to-theme-600 text-white px-6 py-4 rounded-xl hover:from-theme-600 hover:to-theme-700 transition-all transform hover:scale-105">
              <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253">
                </path>
              </svg>
              <span class="font-semibold">Buy Diamonds</span>
            </a>
          </div>
        </div>

        <!-- Recent Transactions -->
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 md:p-8 border border-white/20 animate-slide-up">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl md:text-2xl font-bold text-white">Recent Transactions</h3>
            <a href="/profile"
              class="text-theme-300 hover:text-theme-200 font-medium transition-colors duration-300">View All</a>
          </div>

          <% if (transactions && transactions.length> 0) { %>
            <div class="space-y-4">
              <% transactions.slice(0, 5).forEach(transaction=> { %>
                <div class="flex items-center justify-between p-4 bg-white/5 rounded-xl border border-white/10">
                  <div class="flex items-center">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center mr-4
                    <%= transaction.status === 'approved' ? 'bg-green-500/20 text-green-300' : 
                        transaction.status === 'rejected' ? 'bg-red-500/20 text-red-300' : 
                        'bg-yellow-500/20 text-yellow-300' %>">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                        <% if (transaction.status==='approved' ) { %>
                          <path fill-rule="evenodd"
                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                            clip-rule="evenodd"></path>
                          <% } else if (transaction.status==='rejected' ) { %>
                            <path fill-rule="evenodd"
                              d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                              clip-rule="evenodd"></path>
                            <% } else { %>
                              <path fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z"
                                clip-rule="evenodd"></path>
                              <% } %>
                      </svg>
                    </div>
                    <div>
                      <p class="font-semibold text-white">Top-up Request</p>
                      <p class="text-sm text-gray-300">
                        <%= transaction.payment_type %> • <%= new Date(transaction.created_at).toLocaleDateString() %>
                      </p>
                      <% if (transaction.status==='rejected' && transaction.reason) { %>
                        <p class="text-sm text-red-300 mt-1">
                          <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                              d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                              clip-rule="evenodd"></path>
                          </svg>
                          <%= transaction.reason %>
                        </p>
                        <% } %>
                    </div>
                  </div>
                  <div class="text-right">
                    <p class="font-bold text-white">
                      <%= transaction.amount %>
                        <%= transaction.currency %>
                    </p>
                    <span class="inline-block px-3 py-1 rounded-full text-xs font-medium
                    <%= transaction.status === 'approved' ? 'bg-green-500/20 text-green-300' : 
                        transaction.status === 'rejected' ? 'bg-red-500/20 text-red-300' : 
                        'bg-yellow-500/20 text-yellow-300' %>">
                      <%= transaction.status.charAt(0).toUpperCase() + transaction.status.slice(1) %>
                    </span>
                  </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
              <div class="text-center py-8">
                <div class="text-6xl mb-4">📝</div>
                <h4 class="text-xl font-semibold text-white mb-2">No Transactions Yet</h4>
                <p class="text-gray-300 mb-4">Start by topping up your wallet to see transaction history</p>
                <a href="/wallet/topup"
                  class="inline-flex items-center bg-gradient-to-r from-theme-500 to-theme-600 text-white px-6 py-3 rounded-lg hover:from-theme-600 hover:to-theme-700 transition-all duration-300 transform hover:scale-105">
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                  </svg>
                  Make Your First Top-up
                </a>
              </div>
              <% } %>
        </div>
      </div>
    </section>

    <%- include('../partials/ml-scripts') %>

      <!-- Toast Notifications -->
      <% if (typeof successToast !=='undefined' && successToast) { %>
        <script>
          document.addEventListener('DOMContentLoaded', function () {
            showSuccessToast('<%= successToast %>');
          });
        </script>
        <% } %>

          <% if (typeof errorToast !=='undefined' && errorToast) { %>
            <script>
              document.addEventListener('DOMContentLoaded', function () {
                showErrorToast('<%= errorToast %>');
              });
            </script>
            <% } %>
</body>

</html>