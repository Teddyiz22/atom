<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: 'Forgot Password - ATOM Game Shop' ,
    description: 'Reset your ATOM Game Shop account password securely.' }) %>
</head>

<body class="bg-gray-50 font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>

    <!-- Forgot Password Section -->
    <section class="relative min-h-screen flex items-center justify-center pt-16">
      <!-- Modern Gradient Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
      </div>

      <!-- Reset Form -->
      <div class="relative z-10 w-full max-w-md mx-auto px-4">
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-8 shadow-2xl border border-white/20">

          <!-- Reset Password Form -->
          <div id="resetForm" <% if (typeof success !=='undefined' && success) { %>class="hidden"<% } %>>
              <!-- Header -->
              <div class="text-center mb-8">
                <div
                  class="w-20 h-20 bg-gradient-to-br from-theme-400 to-theme-600 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z">
                    </path>
                  </svg>
                </div>
                <h2 class="text-3xl font-bold text-white mb-2">Forgot Password?</h2>
                <p class="text-white/80">No worries! Enter your email and we'll send you reset instructions.</p>
              </div>

              <!-- Messages -->
              <% if (typeof error !=='undefined' && error) { %>
                <div
                  class="mb-6 p-4 <% if (typeof isGoogleUser !== 'undefined' && isGoogleUser) { %>bg-blue-500/20 border border-blue-500/50<% } else { %>bg-red-500/20 border border-red-500/50<% } %> rounded-lg <% if (typeof isGoogleUser !== 'undefined' && isGoogleUser) { %>text-blue-200<% } else { %>text-red-200<% } %> backdrop-blur-sm">
                  <% if (typeof isGoogleUser !=='undefined' && isGoogleUser) { %>
                    <div class="flex items-center mb-3">
                      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      <strong>Google Account Detected</strong>
                    </div>
                    <% } %>
                      <%= error %>
                        <% if (typeof isGoogleUser !=='undefined' && isGoogleUser) { %>
                          <div class="mt-3">
                            <a href="/users/login"
                              class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors duration-300">
                              <svg class="w-4 h-4 mr-2" viewBox="0 0 24 24">
                                <path fill="currentColor"
                                  d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                                <path fill="currentColor"
                                  d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                                <path fill="currentColor"
                                  d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                                <path fill="currentColor"
                                  d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                              </svg>
                              Go to Login Page
                            </a>
                          </div>
                          <% } %>
                </div>
                <% } %>

                  <!-- Reset Form -->
                  <form action="/users/forgot-password" method="POST" class="space-y-6">
                    <!-- Email -->
                    <div>
                      <label for="email" class="block text-white/90 text-sm font-medium mb-2">Email Address</label>
                      <input type="email" id="email" name="email" required
                        class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-lg text-white placeholder-white/60 focus:outline-none focus:ring-2 focus:ring-theme-400 focus:border-transparent transition-all duration-300"
                        placeholder="Enter your registered email">
                    </div>

                    <!-- Reset Button -->
                    <button type="submit"
                      class="w-full bg-gradient-to-r from-theme-500 to-theme-600 text-white font-bold py-3 px-4 rounded-lg hover:from-theme-600 hover:to-theme-700 transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl">
                      Send Reset Instructions
                    </button>

                    <!-- Back to Login -->
                    <div class="text-center">
                      <a href="/users/login"
                        class="text-theme-300 hover:text-theme-200 font-medium transition-colors duration-300 flex items-center justify-center">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18">
                          </path>
                        </svg>
                        Back to Login
                      </a>
                    </div>
                  </form>
          </div>

          <!-- Success Message -->
          <div id="successMessage" <% if (typeof success==='undefined' || !success) { %>class="hidden"<% } %>>
              <div class="text-center mb-8">
                <div
                  class="w-20 h-20 bg-gradient-to-br from-theme-400 to-theme-600 rounded-full flex items-center justify-center mx-auto mb-4">
                  <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <h2 class="text-3xl font-bold text-white mb-2">Check Your Email!</h2>
                <p class="text-white/80 mb-6">We've sent password reset instructions to your email address.</p>
              </div>

              <div class="space-y-4">
                <div class="bg-white/5 rounded-lg p-4 border border-white/20">
                  <h3 class="text-white font-semibold mb-2">What's next?</h3>
                  <ul class="text-white/80 text-sm space-y-2">
                    <li class="flex items-center">
                      <span class="w-2 h-2 bg-theme-400 rounded-full mr-3"></span>
                      Check your email inbox and spam folder
                    </li>
                    <li class="flex items-center">
                      <span class="w-2 h-2 bg-theme-400 rounded-full mr-3"></span>
                      Click the reset link in the email
                    </li>
                    <li class="flex items-center">
                      <span class="w-2 h-2 bg-theme-400 rounded-full mr-3"></span>
                      Create a new secure password
                    </li>
                    <li class="flex items-center">
                      <span class="w-2 h-2 bg-theme-400 rounded-full mr-3"></span>
                      Log in with your new password
                    </li>
                  </ul>
                </div>

                <div class="text-center space-y-4">
                  <p class="text-white/70 text-sm">
                    Didn't receive the email? Check your spam folder or
                  </p>
                  <form action="/users/forgot-password" method="POST" class="inline">
                    <button type="submit"
                      class="text-theme-300 hover:text-theme-200 font-medium transition-colors duration-300">
                      Send again
                    </button>
                  </form>
                </div>

                <div class="text-center pt-4 border-t border-white/20">
                  <a href="/users/login"
                    class="text-theme-300 hover:text-theme-200 font-medium transition-colors duration-300 flex items-center justify-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18">
                      </path>
                    </svg>
                    Back to Login
                  </a>
                </div>
              </div>
          </div>
        </div>
      </div>
    </section>


    <%- include('../partials/ml-scripts') %>

</body>

</html>