<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: 'Reset Password - ATOM Game Shop' ,
    description: 'Create a new password for your ATOM Game Shop account.' }) %>
</head>

<body class="bg-gray-50 font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>

    <!-- Reset Password Section -->
    <section class="relative min-h-screen flex items-center justify-center pt-16">
      <!-- Modern Gradient Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
      </div>

      <!-- Reset Form -->
      <div class="relative z-10 w-full max-w-md mx-auto px-4">
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-8 shadow-2xl border border-white/20">

          <% if (typeof token !=='undefined' && token) { %>
            <!-- Reset Password Form -->
            <div class="text-center mb-8">
              <div
                class="w-20 h-20 bg-gradient-to-br from-green-400 to-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z">
                  </path>
                </svg>
              </div>
              <h2 class="text-3xl font-bold text-white mb-2">Create New Password</h2>
              <p class="text-white/80">Please enter a strong password for your account</p>
            </div>

            <!-- Messages -->
            <% if (typeof error !=='undefined' && error) { %>
              <div class="mb-6 p-4 bg-red-500/20 border border-red-500/50 rounded-lg text-red-200 backdrop-blur-sm">
                <%= error %>
              </div>
              <% } %>

                <% if (typeof success !=='undefined' && success) { %>
                  <div
                    class="mb-6 p-4 bg-green-500/20 border border-green-500/50 rounded-lg text-green-200 backdrop-blur-sm">
                    <%= success %>
                  </div>
                  <% } %>

                    <!-- Reset Password Form -->
                    <form action="/users/reset-password/<%= token %>" method="POST" class="space-y-6">
                      <!-- New Password -->
                      <div>
                        <label for="password" class="block text-white/90 text-sm font-medium mb-2">New Password</label>
                        <input type="password" id="password" name="password" required
                          class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-lg text-white placeholder-white/60 focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition-all duration-300"
                          placeholder="Enter your new password">
                        <div class="text-white/60 text-xs mt-1">Password must be at least 6 characters long</div>
                      </div>

                      <!-- Confirm Password -->
                      <div>
                        <label for="confirmPassword" class="block text-white/90 text-sm font-medium mb-2">Confirm New
                          Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" required
                          class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-lg text-white placeholder-white/60 focus:outline-none focus:ring-2 focus:ring-green-400 focus:border-transparent transition-all duration-300"
                          placeholder="Confirm your new password">
                      </div>

                      <!-- Reset Button -->
                      <button type="submit"
                        class="w-full bg-gradient-to-r from-green-500 to-green-600 text-white font-bold py-3 px-4 rounded-lg hover:from-green-600 hover:to-green-700 transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl">
                        Reset Password
                      </button>

                      <!-- Back to Login -->
                      <div class="text-center">
                        <a href="/users/login"
                          class="text-theme-300 hover:text-theme-200 font-medium transition-colors duration-300 flex items-center justify-center">
                          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M10 19l-7-7m0 0l7-7m-7 7h18">
                            </path>
                          </svg>
                          Back to Login
                        </a>
                      </div>
                    </form>

                    <% } else { %>
                      <!-- Invalid Token -->
                      <div class="text-center mb-8">
                        <div
                          class="w-20 h-20 bg-gradient-to-br from-red-400 to-red-600 rounded-full flex items-center justify-center mx-auto mb-4">
                          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.35 16.5c-.77.833.192 2.5 1.732 2.5z">
                            </path>
                          </svg>
                        </div>
                        <h2 class="text-3xl font-bold text-white mb-2">Invalid Reset Link</h2>
                        <p class="text-white/80">This password reset link is invalid or has expired.</p>
                      </div>

                      <!-- Messages -->
                      <% if (typeof error !=='undefined' && error) { %>
                        <div
                          class="mb-6 p-4 bg-red-500/20 border border-red-500/50 rounded-lg text-red-200 backdrop-blur-sm">
                          <%= error %>
                        </div>
                        <% } %>

                          <div class="space-y-4">
                            <div class="bg-white/5 rounded-lg p-4 border border-white/20">
                              <h3 class="text-white font-semibold mb-2">What you can do:</h3>
                              <ul class="text-white/80 text-sm space-y-2">
                                <li class="flex items-center">
                                  <span class="w-2 h-2 bg-theme-400 rounded-full mr-3"></span>
                                  Request a new password reset
                                </li>
                                <li class="flex items-center">
                                  <span class="w-2 h-2 bg-theme-400 rounded-full mr-3"></span>
                                  Check if you clicked the latest reset link
                                </li>
                                <li class="flex items-center">
                                  <span class="w-2 h-2 bg-theme-400 rounded-full mr-3"></span>
                                  Contact support if you need help
                                </li>
                              </ul>
                            </div>

                            <div class="text-center space-y-4">
                              <a href="/users/forgot-password"
                                class="w-full bg-gradient-to-r from-theme-500 to-theme-600 text-white font-bold py-3 px-4 rounded-lg hover:from-theme-600 hover:to-theme-700 transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl block">
                                Request New Reset Link
                              </a>

                              <a href="/users/login"
                                class="text-theme-300 hover:text-theme-200 font-medium transition-colors duration-300 flex items-center justify-center">
                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M10 19l-7-7m0 0l7-7m-7 7h18">
                                  </path>
                                </svg>
                                Back to Login
                              </a>
                            </div>
                          </div>
                          <% } %>
        </div>
      </div>
    </section>
    <%- include('../partials/ml-scripts') %>

</body>

</html>