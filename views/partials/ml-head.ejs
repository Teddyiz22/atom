<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Primary Meta Tags -->
<title>
  <%= title %>
</title>
<% if (typeof description !=='undefined' ) { %>
<meta name="description" content="<%= description %>">
<% } %>

<!-- SEO Meta Tags -->
<% if (typeof keywords !=='undefined' ) { %>
<meta name="keywords" content="<%= keywords %>">
<% } else { %>
<meta name="keywords" content="ATOM Game Shop, Mobile Legends diamonds, ML diamonds, diamond top up, gaming top up, Myanmar gaming, MMK currency, mobile gaming, PUBG, Honor of Kings, gaming store, diamond store, affordable gaming, balanced service, 5 star reviews, gaming community, top up service, instant diamonds, secure payment, gaming currency">
<% } %>
<meta name="author" content="ATOM Game Shop">
<meta name="robots" content="index, follow">
<meta name="language" content="English">
<meta name="revisit-after" content="1 days">
<meta name="rating" content="general">
<meta name="distribution" content="global">
<meta name="expires" content="never">

<!-- Canonical URL -->
<link rel="canonical" href="https://atomgameshop.com<%= typeof currentPath !== 'undefined' ? currentPath : '/' %>">

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website">
<meta property="og:url" content="https://atomgameshop.com<%= typeof currentPath !== 'undefined' ? currentPath : '/' %>">
<meta property="og:title" content="<%= title %>">
<% if (typeof description !=='undefined' ) { %>
<meta property="og:description" content="<%= description %>">
<% } %>
<meta property="og:image" content="https://atomgameshop.com/images/logo_cropped.png">
<meta property="og:image:alt" content="ATOM Game Shop Logo">
<meta property="og:site_name" content="ATOM Game Shop">
<meta property="og:locale" content="en_US">
<meta property="og:locale:alternate" content="my_MM">

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image">
<meta property="twitter:url" content="https://atomgameshop.com<%= typeof currentPath !== 'undefined' ? currentPath : '/' %>">
<meta property="twitter:title" content="<%= title %>">
<% if (typeof description !=='undefined' ) { %>
<meta property="twitter:description" content="<%= description %>">
<% } %>
<meta property="twitter:image" content="https://atomgameshop.com/images/logo_cropped.png">
<meta property="twitter:image:alt" content="ATOM Game Shop Logo">

<!-- Schema.org structured data -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [{
        "@type": "Organization",
        "@id": "https://atomgameshop.com/#organization",
        "name": "ATOM Game Shop",
        "url": "https://atomgameshop.com",
        "logo": {
          "@type": "ImageObject",
          "url": "https://atomgameshop.com/images/logo_cropped.png",
          "width": 512,
          "height": 512
        },
        "description": "Your trusted diamond store providing affordable prices and balanced service for Mobile Legends, PUBG, and Honor of Kings since March 2022.",
        "foundingDate": "2022-03-30",
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "5.0",
          "reviewCount": "26100"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "areaServed": "MM",
          "availableLanguage": ["English", "Myanmar"]
        },
        "sameAs": [
          "https://www.facebook.com/atomgameshop"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://atomgameshop.com/#website",
        "url": "https://atomgameshop.com",
        "name": "ATOM Game Shop",
        "description": "Your diamond store - Top up in seconds, play for hours",
        "publisher": {
          "@id": "https://atomgameshop.com/#organization"
        },
        "potentialAction": [{
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://atomgameshop.com/shop?search={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }]
      }
      <% if (typeof currentPath !== 'undefined' && currentPath === '/') { %>,
      {
        "@type": "WebPage",
        "@id": "https://atomgameshop.com/#webpage",
        "url": "https://atomgameshop.com",
        "name": "<%= title %>",
        "isPartOf": {
          "@id": "https://atomgameshop.com/#website"
        },
        "about": {
          "@id": "https://atomgameshop.com/#organization"
        },
        "description": "<%= typeof description !== 'undefined' ? description : 'Your diamond store - Top up in seconds, play for hours' %>",
        "breadcrumb": {
          "@id": "https://atomgameshop.com/#breadcrumb"
        },
        "inLanguage": "en-US"
      },
      {
        "@type": "BreadcrumbList",
        "@id": "https://atomgameshop.com/#breadcrumb",
        "itemListElement": [{
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://atomgameshop.com"
        }]
      }
      <% } %>
    ]
  }
</script>

<!-- Additional SEO Meta Tags -->
<meta name="theme-color" content="#38B6FF">
<meta name="msapplication-TileColor" content="#38B6FF">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="ATOM Game Shop">

<!-- Favicon -->
<link rel="icon" type="image/x-icon" href="/images/logo_cropped.png">
<link rel="apple-touch-icon" href="/images/logo_cropped.png">

<!-- Preconnect to external domains for performance -->
<link rel="preconnect" href="https://cdn.tailwindcss.com">
<link rel="preconnect" href="https://cdn.jsdelivr.net">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- DNS prefetch for better performance -->
<link rel="dns-prefetch" href="//cdn.tailwindcss.com">
<link rel="dns-prefetch" href="//cdn.jsdelivr.net">

<!-- Tailwind CSS CDN -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- Toastify CSS -->
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

<!-- Custom CSS -->
<link rel="stylesheet" href="/css/ml-styles.css">
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          primary: '#38B6FF',
          secondary: '#2493D4',
          accent: '#353535',
          post: '#94B4D3',
          mlblue: '#38B6FF',
          mlgold: '#2493D4',
          mlpurple: '#353535',
          theme: {
            50: '#e6f7ff',
            100: '#b3e9ff',
            200: '#80dbff',
            300: '#4dcdff',
            400: '#38B6FF',
            500: '#2493D4',
            600: '#1f7db8',
            700: '#1a679c',
            800: '#155180',
            900: '#353535',
            950: '#2a2a2a'
          }
        },
        backgroundImage: {
          'ml-gradient': 'linear-gradient(135deg, #38B6FF 0%, #2493D4 50%, #353535 100%)',
          'hero-ml': 'linear-gradient(135deg, rgba(56, 182, 255, 0.9) 0%, rgba(36, 147, 212, 0.8) 50%, rgba(53, 53, 53, 0.9) 100%)',
          'hero-pattern': "url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"0.1\"%3E%3Ccircle cx=\"30\" cy=\"30\" r=\"2\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')"
        },
        animation: {
          'float': 'float 6s ease-in-out infinite',
          'float-delay': 'float 6s ease-in-out infinite 2s',
          'float-slow': 'float 8s ease-in-out infinite',
          'glow': 'glow 2s ease-in-out infinite alternate',
          'glow-pulse': 'glowPulse 3s ease-in-out infinite',
          'bounce-slow': 'bounce 3s infinite',
          'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
          'fade-in': 'fadeIn 0.8s ease-out',
          'fade-in-up': 'fadeInUp 1s ease-out',
          'fade-in-down': 'fadeInDown 1s ease-out',
          'slide-up': 'slideUp 0.6s ease-out',
          'slide-in-left': 'slideInLeft 0.8s ease-out',
          'slide-in-right': 'slideInRight 0.8s ease-out',
          'text-reveal': 'textReveal 1.2s ease-out',
          'scale-in': 'scaleIn 0.6s ease-out',
          'rotate-slow': 'rotateSlow 20s linear infinite',
          'particle-float': 'particleFloat 15s ease-in-out infinite',
          'shimmer': 'shimmer 2s linear infinite',
          'gradient-shift': 'gradientShift 4s ease-in-out infinite',
          'typing': 'typing 3.5s steps(40, end)',
          'blink-caret': 'blinkCaret 1s infinite',
        }
      }
    }
  }
</script>
<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideUp {
    from {
      transform: translateY(20px);
      opacity: 0;
    }

    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-50px);
    }

    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(50px);
    }

    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes textReveal {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.9);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.8);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes float {

    0%,
    100% {
      transform: translateY(0px);
    }

    50% {
      transform: translateY(-20px);
    }
  }

  @keyframes rotateSlow {
    from {
      transform: rotate(0deg);
    }

    to {
      transform: rotate(360deg);
    }
  }

  @keyframes particleFloat {

    0%,
    100% {
      transform: translateY(0px) translateX(0px);
    }

    25% {
      transform: translateY(-30px) translateX(10px);
    }

    50% {
      transform: translateY(-60px) translateX(-5px);
    }

    75% {
      transform: translateY(-30px) translateX(-10px);
    }
  }

  @keyframes glowPulse {

    0%,
    100% {
      filter: drop-shadow(0 0 20px rgba(148, 180, 211, 0.5));
    }

    50% {
      filter: drop-shadow(0 0 40px rgba(148, 180, 211, 0.8));
    }
  }

  @keyframes shimmer {
    0% {
      background-position: -200px 0;
    }

    100% {
      background-position: calc(200px + 100%) 0;
    }
  }

  @keyframes gradientShift {

    0%,
    100% {
      background-position: 0% 50%;
    }

    50% {
      background-position: 100% 50%;
    }
  }

  @keyframes typing {
    from {
      width: 0;
    }

    to {
      width: 100%;
    }
  }

  @keyframes blinkCaret {

    from,
    to {
      border-color: transparent;
    }

    50% {
      border-color: #94b4d3;
    }
  }

  /* Floating particles */
  .particle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
  }

  .particle-1 {
    width: 4px;
    height: 4px;
    background: rgba(148, 180, 211, 0.6);
    top: 20%;
    left: 10%;
    animation: particleFloat 15s ease-in-out infinite;
  }

  .particle-2 {
    width: 6px;
    height: 6px;
    background: rgba(138, 168, 198, 0.5);
    top: 60%;
    left: 80%;
    animation: particleFloat 18s ease-in-out infinite reverse;
  }

  .particle-3 {
    width: 3px;
    height: 3px;
    background: rgba(126, 163, 201, 0.7);
    top: 40%;
    left: 90%;
    animation: particleFloat 12s ease-in-out infinite;
  }

  .particle-4 {
    width: 5px;
    height: 5px;
    background: rgba(148, 180, 211, 0.4);
    top: 80%;
    left: 20%;
    animation: particleFloat 20s ease-in-out infinite reverse;
  }

  .particle-5 {
    width: 2px;
    height: 2px;
    background: rgba(184, 208, 230, 0.8);
    top: 15%;
    left: 70%;
    animation: particleFloat 16s ease-in-out infinite;
  }

  .particle-6 {
    width: 4px;
    height: 4px;
    background: rgba(138, 168, 198, 0.6);
    top: 70%;
    left: 5%;
    animation: particleFloat 14s ease-in-out infinite reverse;
  }

  /* Shimmer effect for buttons */
  .shimmer-button {
    background: linear-gradient(90deg,
        rgba(148, 180, 211, 0.1) 0%,
        rgba(148, 180, 211, 0.3) 50%,
        rgba(148, 180, 211, 0.1) 100%);
    background-size: 200px 100%;
    animation: shimmer 2s linear infinite;
  }

  /* Gradient text animation */
  .gradient-text {
    background: linear-gradient(-45deg, #94b4d3, #7ea3c9, #6688b0, #94b4d3);
    background-size: 400% 400%;
    animation: gradientShift 4s ease-in-out infinite;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Stagger animation delays */
  .stagger-1 {
    animation-delay: 0.1s;
  }

  .stagger-2 {
    animation-delay: 0.2s;
  }

  .stagger-3 {
    animation-delay: 0.3s;
  }

  .stagger-4 {
    animation-delay: 0.4s;
  }

  .stagger-5 {
    animation-delay: 0.5s;
  }

  .stagger-6 {
    animation-delay: 0.6s;
  }

  /* Scroll reveal animation */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(50px);
    transition: all 0.8s ease;
  }

  .scroll-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Modern glassmorphism hover effects */
  .glass-hover {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .glass-hover:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }

  /* Loading animation */
  .loading-bar {
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, #94b4d3, #7ea3c9);
    animation: loadingBar 2s ease-out forwards;
  }

  @keyframes loadingBar {
    to {
      width: 100%;
    }
  }

  /* Theme colors and animations */
  :root {
    --theme-50: #f0f8ff;
    --theme-100: #e0f0ff;
    --theme-200: #c0e0ff;
    --theme-300: #94b4d3;
    --theme-400: #6a9bd1;
    --theme-500: #4682b4;
    --theme-600: #2e5c8a;
    --theme-700: #1e3d5c;
    --theme-800: #0f1e2e;
    --theme-900: #0a1520;
    --theme-950: #050a10;
  }

  /* Language dropdown specific styles */
  .language-dropdown {
    position: absolute !important;
    z-index: 9999 !important;
    pointer-events: auto !important;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.1) !important;
  }

  .language-dropdown a {
    display: block !important;
    text-decoration: none !important;
    cursor: pointer !important;
  }

  .language-dropdown a:hover {
    background-color: rgba(148, 180, 211, 0.2) !important;
  }

  /* Prevent dropdown from interfering with other elements */
  .relative.z-50 {
    isolation: isolate;
  }

  /* Mobile menu improvements */
  #mobile-menu {
    z-index: 40 !important;
  }

  /* Ensure navigation stays on top */
  nav {
    z-index: 50 !important;
  }

  /* Gradient text animation */
  .gradient-text {
    background: linear-gradient(45deg, var(--theme-300), var(--theme-500), var(--theme-300));
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradient-shift 3s ease-in-out infinite;
  }
</style>

<!-- Include Toast System -->
<%- include('./toast') %>

