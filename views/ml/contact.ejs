<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: 'Contact Us - ATOM Game Shop' ,
    description: 'Get in touch with ATOM Game Shop. Fast customer support for all your gaming top-up needs.' }) %>
</head>

<body class="bg-gray-50 font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>

  <!-- Contact Section -->
  <section class="relative pt-20 pb-16 min-h-screen">
    <!-- Modern Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
    </div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
    </div>

    <!-- Hero Section -->
    <div class="relative z-10 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="animate-fade-in">
          <h1 class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent mb-6">
            Get in Touch
          </h1>
          <p class="text-lg md:text-xl text-gray-300 max-w-3xl mx-auto">
            Need help with your gaming top-ups? Our support team is here 24/7 to assist you.
          </p>
        </div>
      </div>
    </div>

    <!-- Contact Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid lg:grid-cols-1 gap-12">

        <!-- Contact Information -->
        <div class="animate-slide-up">
          <div class="bg-white/10 backdrop-blur-md rounded-2xl shadow-xl p-6 md:p-8 border border-white/20">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-8">Contact Information</h2>

            <!-- Contact Cards -->
            <div class="space-y-6">
              <!-- Support Hours -->
              <div class="flex items-start space-x-4 p-4 bg-white/10 border border-white/20 rounded-xl backdrop-blur-sm">
                <div class="w-12 h-12 bg-gradient-to-br from-theme-500 to-theme-600 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-white mb-1">Support Hours</h3>
                  <p class="text-gray-300 text-sm">24/7 Customer Support</p>
                  <p class="text-gray-400 text-sm">Always here to help you!</p>
                </div>
              </div>

              <!-- Email Support -->
              <div class="flex items-start space-x-4 p-4 bg-white/10 border border-white/20 rounded-xl backdrop-blur-sm">
                <div class="w-12 h-12 bg-gradient-to-br from-theme-500 to-theme-600 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z">
                    </path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-white mb-1">Email Support</h3>
                  <p class="text-gray-300 text-sm">support@atomgameshop.com</p>
                  <p class="text-gray-400 text-sm">Response within 1 hour</p>
                </div>
              </div>

              <!-- Telegram Support -->
              <div class="flex items-start space-x-4 p-4 bg-white/10 border border-white/20 rounded-xl backdrop-blur-sm">
                <div class="w-12 h-12 bg-gradient-to-br from-theme-500 to-theme-600 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-white mb-1">Telegram Support</h3>
                  <p class="text-gray-300 text-sm">@atomgameshop</p>
                  <p class="text-gray-400 text-sm">Instant messaging support</p>
                </div>
              </div>

              <!-- Quick Response -->
              <div class="flex items-start space-x-4 p-4 bg-white/10 border border-white/20 rounded-xl backdrop-blur-sm">
                <div class="w-12 h-12 bg-gradient-to-br from-theme-500 to-theme-600 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-white mb-1">Quick Response</h3>
                  <p class="text-gray-300 text-sm">Average response time: 5 minutes</p>
                  <p class="text-gray-400 text-sm">Fast resolution guaranteed</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- <div class="animate-slide-up">
          <div class="bg-white/10 backdrop-blur-md rounded-2xl shadow-xl p-6 md:p-8 border border-white/20">
