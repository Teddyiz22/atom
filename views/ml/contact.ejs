              </div>


              <button type="submit" class="w-full bg-gradient-to-r from-theme-400 to-theme-600 text-white font-bold py-3 px-4 rounded-lg hover:from-theme-500 hover:to-theme-700 transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl">
                Send Message
              </button>
            </form>
          </div>
        </div> -->
      </div>
    </div>
  </section>

  <!-- Floating Telegram Button -->
  <div class="fixed bottom-6 right-6 z-50">
    <a href="https://t.me/atomgameshop" target="_blank" rel="noopener noreferrer" class="group relative bg-gradient-to-br from-theme-500 to-theme-600 text-white p-3 md:p-4 rounded-full shadow-lg hover:shadow-xl transform hover:scale-110 transition-all duration-300 animate-pulse hover:animate-none flex items-center justify-center">

      <!-- Telegram Icon -->
      <svg class="w-6 h-6 md:w-7 md:h-7" fill="currentColor" viewBox="0 0 24 24">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" />
      </svg>

      <!-- Pulse rings -->
      <span class="absolute -inset-2 bg-theme-400/30 rounded-full animate-ping group-hover:animate-none opacity-75"></span>
      <span class="absolute -inset-1 bg-theme-400/20 rounded-full animate-ping group-hover:animate-none opacity-50 animation-delay-75"></span>

      <!-- Tooltip -->
      <div class="absolute bottom-full right-0 mb-3 px-3 py-2 bg-black/80 text-white text-sm rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap backdrop-blur-sm">
        Contact us on Telegram
        <div class="absolute top-full right-3 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-black/80">
        </div>
      </div>

      <!-- Mobile tap indicator -->
      <div class="md:hidden absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full animate-bounce"></div>
    </a>
  </div>


  <%- include('../partials/ml-scripts') %>
    <%- include('../partials/ml-floating-nav') %>
</body>

</html>