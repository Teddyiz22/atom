<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: __('terms_conditions.title') + ' - ATOM Game Shop',
    description: 'Terms & Conditions for ATOM Game Shop services.' }) %>
</head>

<body class="bg-gray-50 font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>

  <!-- Section -->
  <section class="relative pt-20 pb-16 min-h-screen">
    <!-- Modern Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
    </div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
    </div>

    <!-- Hero Section -->
    <div class="relative z-10 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="animate-fade-in">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 shadow-lg shadow-blue-500/30 mb-6 transform rotate-3">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h1 class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent mb-6">
            <%= __('terms_conditions.title') %>
          </h1>
          <div class="flex flex-col md:flex-row items-center justify-center gap-4 text-gray-400 text-sm">
            <span class="flex items-center bg-white/5 px-4 py-2 rounded-full border border-white/10">
              <svg class="w-4 h-4 mr-2 text-theme-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <%= __('terms_conditions.effective_date') %>
            </span>
            <span class="flex items-center bg-white/5 px-4 py-2 rounded-full border border-white/10">
              <svg class="w-4 h-4 mr-2 text-theme-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
              <%= __('terms_conditions.website') %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="bg-gray-900/60 backdrop-blur-xl rounded-3xl shadow-2xl p-8 md:p-12 border border-white/10 animate-slide-up">
        
        <!-- Intro -->
        <% if (__('terms_conditions.intro')) { %>
          <div class="bg-gradient-to-r from-blue-500/10 to-indigo-500/10 border border-blue-500/20 rounded-2xl p-6 mb-12">
            <p class="text-lg text-blue-100 leading-relaxed"><%= __('terms_conditions.intro') %></p>
          </div>
        <% } %>
        
        <!-- Sections Grid -->
        <div class="grid gap-6">
          <% const sections = __('terms_conditions.sections'); %>
          <% if (Array.isArray(sections)) { %>
            <% sections.forEach((section, index) => { %>
              <div class="group relative bg-white/5 rounded-2xl p-6 md:p-8 border border-white/5 hover:bg-white/10 hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
                <!-- Section Header -->
                <div class="flex items-start gap-4 mb-4">
                  <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-xl bg-gradient-to-br from-theme-500 to-theme-700 text-white font-bold text-lg shadow-lg group-hover:scale-110 transition-transform duration-300">
                    <%= index + 1 %>
                  </div>
                  <h3 class="text-xl font-bold text-white group-hover:text-theme-400 transition-colors pt-1.5">
                    <%= section.title.replace(/^\d+[.၊]\s*/, '') %>
                  </h3>
                </div>
                
                <!-- Content -->
                <div class="pl-0 md:pl-14">
                  <% if (section.content) { %>
                    <p class="text-gray-400 leading-relaxed mb-4"><%= section.content %></p>
                  <% } %>
                  
                  <% if (section.list && Array.isArray(section.list)) { %>
                    <ul class="space-y-3 mt-4">
                      <% section.list.forEach(item => { %>
                        <li class="flex items-start text-gray-400">
                          <svg class="w-5 h-5 mr-3 text-theme-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                          <span><%= item %></span>
                        </li>
                      <% }) %>
                    </ul>
                  <% } %>

                  <% if (section.contact_link) { %>
                    <div class="mt-6 inline-block">
                      <a href="<%= section.contact_link.url %>" target="_blank" class="inline-flex items-center px-5 py-2.5 rounded-xl bg-[#229ED9]/20 text-[#229ED9] hover:bg-[#229ED9]/30 transition-all duration-300 border border-[#229ED9]/30 hover:shadow-lg hover:shadow-[#229ED9]/20">
                        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.48-1-2.42-1.61-1.09-.72-.38-1.13.23-1.78.14-.15 2.6-2.38 2.65-2.58.01-.02.01-.1-.04-.15-.05-.04-.13-.03-.18-.01-.08.02-1.32.84-3.75 2.48-.36.23-.69.35-.98.34-.32-.01-.93-.17-1.38-.32-.56-.18-1-.28-1-.57.01-.29.44-.58 1.15-.88 4.5-1.96 7.51-3.26 9.02-3.9 4.3-.18 5.17 1.16 5.2 1.16l.02.03c.01.12.01.24-.01.4z"/>
                        </svg>
                        <%= section.contact_link.text %>
                      </a>
                    </div>
                  <% } %>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>

      </div>
    </div>
  </section>


  <%- include('../partials/ml-scripts') %>
    <%- include('../partials/ml-floating-nav') %>
</body>

</html>
