<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PUBG Mobile — ATOM Game Shop</title>
  <meta name="description" content="PUBG Mobile UC top-up. Pay from wallet; balance settled when your order is approved.">

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            theme: {
              400: '#38B6FF',
              500: '#2493D4',
              600: '#1f7db8',
              800: '#155180',
              900: '#353535',
              950: '#2a2a2a'
            }
          },
          backgroundImage: {
            'ml-gradient': 'linear-gradient(135deg, #38B6FF 0%, #2493D4 50%, #353535 100%)'
          }
        }
      }
    };
  </script>
</head>

<body class="bg-gray-50 font-sans overflow-x-hidden" data-is-logged-in="<%= user ? '1' : '0' %>">
  <%- include('../partials/ml-nav') %>

  <section class="relative min-h-screen pt-20 pb-16">
    <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
    </div>
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h1 class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">
          PUBG Mobile
        </h1>
        <p class="text-gray-300 mt-2 max-w-2xl mx-auto text-sm md:text-base">
          Select a package and enter your Player ID. Payment is taken from your wallet when you submit.
        </p>
        <% if (user) { %>
        <p class="mt-3 text-green-300 text-sm">Signed in as <span class="font-semibold text-white"><%= user.name %></span></p>
        <% } %>
      </div>

      <div class="bg-amber-500/15 border border-amber-400/40 rounded-2xl p-4 mb-8 text-amber-100 text-sm">
        <strong class="text-amber-200">Important:</strong> Enter your correct Player ID before submitting.
      </div>

      <!-- Account -->
      <div class="bg-white/10 backdrop-blur-md rounded-3xl p-6 border border-white/20 mb-8">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-20 h-20 rounded-2xl overflow-hidden border-2 border-white/30 shrink-0">
            <img src="/images/pubg.png" alt="PUBG" class="w-full h-full object-cover">
          </div>
          <div class="flex-1 min-w-0">
            <h2 class="text-xl font-bold text-white">Pubg Custom</h2>
            <p class="text-white/60 text-sm mt-1">UC packages</p>
            <div class="inline-flex items-center p-0.5 bg-black/30 rounded-full border border-white/10 mt-3">
              <label class="cursor-pointer">
                <input type="radio" name="currency" value="MMK" checked class="peer hidden">
                <div
                  class="px-3 py-1 rounded-full text-[10px] font-bold text-white/50 peer-checked:bg-[#89CFF0] peer-checked:text-white transition-all">
                  MMK</div>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="currency" value="THB" class="peer hidden">
                <div
                  class="px-3 py-1 rounded-full text-[10px] font-bold text-white/50 peer-checked:bg-[#89CFF0] peer-checked:text-white transition-all">
                  THB</div>
              </label>
            </div>
          </div>
        </div>

        <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
          <span class="bg-gradient-to-r from-theme-400 to-theme-600 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm">1</span>
          Account details
        </h3>
        <div class="max-w-xl">
          <label for="playerId" class="block text-white/90 text-sm font-medium mb-2">Player ID *</label>
          <input type="text" id="playerId" required minlength="3" maxlength="64"
            class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-lg text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-theme-400"
            placeholder="Your PUBG Player ID">
        </div>
      </div>

      <!-- Packages -->
      <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20 mb-8">
        <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
          <span class="bg-gradient-to-r from-theme-400 to-theme-600 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm">2</span>
          Select package
        </h3>

        <% if (!products || products.length === 0) { %>
        <p class="text-gray-300 text-center py-8">No packages available yet. Please check back later.</p>
        <% } else { %>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          <% products.forEach(function(product) { %>
          <div
            class="package-card relative bg-white/5 hover:bg-white/10 border border-white/20 rounded-xl p-4 cursor-pointer transition-all duration-300 hover:border-theme-400/60 <%= product.is_featured ? 'ring-2 ring-yellow-400/50' : '' %>"
            data-product-id="<%= product.id %>" data-name="<%- (product.name || '').replace(/"/g, '&quot;') %>"
            data-mmk="<%= product.price_mmk %>" data-thb="<%= product.price_thb %>" onclick="selectPkg(this)">
            <% if (product.is_featured) { %>
            <span class="absolute top-2 left-2 text-[10px] font-bold bg-yellow-500 text-black px-2 py-0.5 rounded-full">FEATURED</span>
            <% } %>
            <div class="flex items-center gap-2 mt-6">
              <img src="/images/uc.png" alt="" class="w-10 h-10 object-contain rounded-lg">
              <p class="text-white font-semibold text-sm leading-tight line-clamp-2"><%= product.name %></p>
            </div>
            <p class="price-mmk text-theme-300 font-bold mt-3 text-center text-sm">
              <%= new Intl.NumberFormat('en-US').format(product.price_mmk) %> MMK
            </p>
            <p class="price-thb text-theme-300 font-bold mt-3 text-center text-sm hidden">
              ฿<%= new Intl.NumberFormat('en-US').format(product.price_thb) %>
            </p>
          </div>
          <% }); %>
        </div>
        <% } %>

        <input type="hidden" id="selectedProductId" value="">

        <div id="selectedBar" class="hidden mt-6 p-4 bg-white/5 border border-white/20 rounded-xl">
          <p class="text-white text-sm"><span class="text-gray-400">Selected:</span> <span id="selectedLabel" class="font-semibold"></span></p>
          <p class="text-theme-300 font-bold mt-1" id="selectedPrice"></p>
        </div>

        <button type="button" id="orderBtn"
          class="w-full mt-6 py-4 rounded-xl bg-gradient-to-r from-theme-500 to-theme-600 text-white font-bold text-lg hover:opacity-95 disabled:opacity-40 disabled:cursor-not-allowed transition-opacity">
          Submit order (wallet)
        </button>
      </div>
    </div>
  </section>

  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] hidden max-w-md px-4 py-3 rounded-xl text-white text-sm shadow-lg"></div>

  <%- include('../partials/ml-scripts') %>
  <script>
    let selected = null;
    let busy = false;

    function showToast(msg, ok) {
      var el = document.getElementById('toast');
      el.textContent = msg;
      el.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] max-w-md px-4 py-3 rounded-xl text-white text-sm shadow-lg ' + (ok ? 'bg-green-600' : 'bg-red-600');
      el.classList.remove('hidden');
      setTimeout(function () { el.classList.add('hidden'); }, 4500);
    }

    function syncCurrencyUI() {
      var cur = document.querySelector('input[name="currency"]:checked');
      cur = cur ? cur.value : 'MMK';
      document.querySelectorAll('.price-mmk').forEach(function (el) { el.classList.toggle('hidden', cur !== 'MMK'); });
      document.querySelectorAll('.price-thb').forEach(function (el) { el.classList.toggle('hidden', cur !== 'THB'); });
      if (selected) updateSelectedBar();
    }

    document.querySelectorAll('input[name="currency"]').forEach(function (r) {
      r.addEventListener('change', syncCurrencyUI);
    });

    function selectPkg(el) {
      document.querySelectorAll('.package-card').forEach(function (c) {
        c.classList.remove('ring-2', 'ring-theme-400', 'bg-white/15');
      });
      el.classList.add('ring-2', 'ring-theme-400', 'bg-white/15');
      selected = {
        id: el.getAttribute('data-product-id'),
        name: el.getAttribute('data-name'),
        mmk: el.getAttribute('data-mmk'),
        thb: el.getAttribute('data-thb')
      };
      document.getElementById('selectedProductId').value = selected.id;
      document.getElementById('selectedBar').classList.remove('hidden');
      updateSelectedBar();
    }

    function updateSelectedBar() {
      if (!selected) return;
      var cur = document.querySelector('input[name="currency"]:checked').value;
      document.getElementById('selectedLabel').textContent = selected.name;
      if (cur === 'MMK') {
        document.getElementById('selectedPrice').textContent = Number(selected.mmk).toLocaleString() + ' MMK';
      } else {
        document.getElementById('selectedPrice').textContent = '฿' + Number(selected.thb).toLocaleString();
      }
    }

    document.getElementById('orderBtn').addEventListener('click', function () {
      if (document.body.getAttribute('data-is-logged-in') !== '1') {
        showToast('Please log in to continue.', false);
        setTimeout(function () { window.location.href = '/users/login'; }, 800);
        return;
      }
      var pid = document.getElementById('selectedProductId').value;
      if (!pid) {
        showToast('Please select a package.', false);
        return;
      }
      var playerId = document.getElementById('playerId').value.trim();
      if (playerId.length < 3) {
        showToast('Enter a valid Player ID.', false);
        return;
      }
      if (busy) return;
      busy = true;
      var btn = document.getElementById('orderBtn');
      btn.disabled = true;
      var cur = document.querySelector('input[name="currency"]:checked').value;
      fetch('/api/manual-game-order', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-csrf-token': '<%= csrfToken %>'
        },
        body: JSON.stringify({
          product_id: parseInt(pid, 10),
          currency: cur,
          player_id: playerId
        })
      })
        .then(function (r) {
          return r.json().then(function (j) { j.__s = r.status; return j; });
        })
        .then(function (j) {
          if (j.__s === 200 && j.status === 200) {
            showToast(j.message || 'Order submitted.', true);
            document.getElementById('selectedProductId').value = '';
            document.getElementById('selectedBar').classList.add('hidden');
            selected = null;
            document.querySelectorAll('.package-card').forEach(function (c) {
              c.classList.remove('ring-2', 'ring-theme-400', 'bg-white/15');
            });
          } else {
            showToast(j.message || 'Order failed.', false);
          }
        })
        .catch(function () { showToast('Network error.', false); })
        .finally(function () {
          busy = false;
          btn.disabled = false;
        });
    });

    syncCurrencyUI();
  </script>
</body>

</html>
