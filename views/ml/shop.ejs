<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: 'ATOM Game Shop - Fast & Secure Mobile Legends Top Up' ,
    description: 'Buy Mobile Legends diamonds instantly! Fast, secure, and affordable ML diamond top-up service. Get your diamonds in seconds!'
    }) %>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shop - ATOM Game Shop</title>
  <meta name="description"
    content="Buy Mobile Legends diamonds instantly with MMK and THB currency. Fast, secure, and affordable diamond top-up service.">

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#38B6FF',
            secondary: '#2493D4',
            accent: '#353535',
            post: '#94B4D3',
            mlblue: '#38B6FF',
            mlgold: '#2493D4',
            mlpurple: '#353535',
            theme: {
              50: '#e6f7ff',
              100: '#b3e9ff',
              200: '#80dbff',
              300: '#4dcdff',
              400: '#38B6FF',
              500: '#2493D4',
              600: '#1f7db8',
              700: '#1a679c',
              800: '#155180',
              900: '#353535',
              950: '#2a2a2a'
            }
          },
          backgroundImage: {
            'ml-gradient': 'linear-gradient(135deg, #38B6FF 0%, #2493D4 50%, #353535 100%)',
            'hero-ml': 'linear-gradient(135deg, rgba(56, 182, 255, 0.9) 0%, rgba(36, 147, 212, 0.8) 50%, rgba(53, 53, 53, 0.9) 100%)',
            'hero-pattern': "url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"0.1\"%3E%3Ccircle cx=\"30\" cy=\"30\" r=\"2\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')"
          },
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'float-slow': 'float 10s ease-in-out infinite',
            'float-delay': 'float 8s ease-in-out infinite 2s',
            'glow': 'glow 2s ease-in-out infinite alternate',
            'bounce-slow': 'bounce 3s infinite',
            'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
            'fade-in': 'fadeIn 0.8s ease-out',
            'slide-up': 'slideUp 0.6s ease-out',
          }
        }
      }
    }
  </script>

  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
      }

      to {
        opacity: 1;
      }
    }

    @keyframes slideUp {
      from {
        transform: translateY(20px);
        opacity: 0;
      }

      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    /* Floating Orbs & Particles */
    @keyframes float {

      0%,
      100% {
        transform: translateY(0) rotate(0deg);
      }

      50% {
        transform: translateY(-20px) rotate(5deg);
      }
    }

    .particle {
      position: absolute;
      width: 4px;
      height: 4px;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 50%;
      animation: particle-fly infinite linear;
      pointer-events: none;
    }

    .particle-1 {
      top: 20%;
      left: 10%;
      animation-duration: 15s;
    }

    .particle-2 {
      top: 60%;
      left: 30%;
      animation-duration: 20s;
    }

    .particle-3 {
      top: 40%;
      left: 80%;
      animation-duration: 18s;
    }

    .particle-4 {
      top: 10%;
      left: 50%;
      animation-duration: 25s;
    }

    .particle-5 {
      top: 80%;
      left: 70%;
      animation-duration: 12s;
    }

    .particle-6 {
      top: 50%;
      left: 50%;
      animation-duration: 22s;
    }

    @keyframes particle-fly {
      0% {
        transform: translate(0, 0);
        opacity: 0;
      }

      50% {
        opacity: 0.5;
      }

      100% {
        transform: translate(100px, -100px);
        opacity: 0;
      }
    }
  </style>
</head>

<body class="bg-[#0a0a0a] font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>

    <section class="relative min-h-screen pt-20 pb-16 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
      </div>

      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="particle particle-1"></div>
        <div class="particle particle-2"></div>
        <div class="particle particle-3"></div>
        <div class="particle particle-4"></div>
        <div class="particle particle-5"></div>
        <div class="particle particle-6"></div>
      </div>

      <div class="absolute top-40 left-[-5%] w-64 h-64 bg-theme-400/10 blur-[100px] rounded-full animate-float-slow">
      </div>
      <div
        class="absolute bottom-40 right-[-5%] w-48 h-48 bg-theme-500/10 blur-[80px] rounded-full animate-float-delay">
      </div>
      <div class="absolute top-1/2 left-10 w-32 h-32 bg-theme-300/10 blur-[60px] rounded-full animate-float"></div>

      <div class="relative z-10">

        <div class="max-w-6xl mx-auto p-4 md:p-8">

          <div class="relative w-full overflow-hidden rounded-3xl shadow-2xl bg-gray-900">
            <div class="flex transition-transform duration-700 ease-out" id="slider">

              <div class="w-full flex-shrink-0">
                <img src="/images/banner.png" class="w-full aspect-[16/9] object-contain bg-black">
              </div>

              <div class="w-full flex-shrink-0">
                <img src="/images/banner.png" class="w-full aspect-[16/9] object-contain bg-black">
              </div>

              <div class="w-full flex-shrink-0">
                <img src="/images/banner.png" class="w-full aspect-[16/9] object-contain bg-black">
              </div>

            </div>
          </div>


        </div>

        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <% if (typeof mode !=='undefined' && mode==='types' ) { %>
            <div class="flex space-x-3 px-4 mt-6">
              <button
                class="px-5 py-2 rounded-full text-white text-sm bg-white/20 backdrop-blur-md border border-white/30 shadow-lg shadow-blue-500/30 hover:bg-white/30 transition">Popular</button>
              <button
                class="px-5 py-2 rounded-full text-white text-sm bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 transition">All
                Games</button>
            </div>

            <%
              const activeTypeCodes = new Set((productTypes || []).map(t => String(t.typeCode || '').toLowerCase()));
              const hasType = (code) => activeTypeCodes.has(String(code || '').toLowerCase());
            %>
            <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 px-4 mt-6 font-mont max-w-5xl mx-auto">

              <% if (hasType('ml')) { %>
              <a href="/shop/ml" class="group">
                <div
                  class="relative rounded-2xl p-2 bg-white/10 backdrop-blur-lg border border-white/20 shadow-md shadow-blue-900/25 hover:scale-105 transition-transform duration-300 h-full">
                  <img src="/images/mlbb_special.png" class="w-full rounded-xl aspect-square object-cover">
                  <p class="text-white text-[8px] sm:text-[8px] text-center mt-2 leading-tight font-bold">Mobile Legends
                  </p>
                  <div
                    class="absolute inset-0 rounded-2xl bg-gradient-to-br from-white/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
                  </div>
                </div>
              </a>
              <% } %>

              <% if (hasType('mlphp')) { %>
              <a href="/shop/mlphp" class="group">
                <div
                  class="relative rounded-2xl p-2 bg-white/10 backdrop-blur-lg border border-white/20 shadow-md shadow-blue-900/25 hover:scale-105 transition-transform duration-300 h-full">
                  <img src="/images/mlbb_special.png" class="w-full rounded-xl aspect-square object-cover">
                  <p class="text-white text-[8px] sm:text-[8px] text-center mt-2 leading-tight font-bold">Mobile Legends
                    Philippines</p>
                </div>
              </a>
              <% } %>

              <% if (hasType('mlbb_special')) { %>
              <a href="/shop/mlbb_special" class="group">
                <div
                  class="relative rounded-2xl p-2 bg-white/10 backdrop-blur-lg border border-white/20 shadow-md shadow-blue-900/25 hover:scale-105 transition-transform duration-300 h-full">
                  <img src="/images/mlbb_special.png" class="w-full rounded-xl aspect-square object-cover">
                  <p class="text-white text-[8px] sm:text-[8px] text-center mt-2 leading-tight font-bold">
                    Mobile Legends Singapore/Malaysia
                  </p>
                </div>
              </a>
              <% } %>

              <% if (hasType('pubgm')) { %>
              <a href="/shop/pubgm" class="group">
                <div
                  class="relative rounded-2xl p-2 bg-white/10 backdrop-blur-lg border border-white/20 shadow-md shadow-blue-900/25 hover:scale-105 transition-transform duration-300 h-full">
                  <img src="/images/pubg.png" class="w-full rounded-xl aspect-square object-cover">
                  <p class="text-white text-[8px] sm:text-[8px] text-center mt-2 leading-tight font-bold">PUBG Mobile
                  </p>
                </div>
              </a>
              <% } %>

              <% if (hasType('pubgcustom')) { %>
              <a href="/shop/pubgcustom" class="group">
                <div
                  class="relative rounded-2xl p-2 bg-white/10 backdrop-blur-lg border border-amber-400/30 shadow-md shadow-amber-900/20 hover:scale-105 transition-transform duration-300 h-full">
                  <img src="/images/pubg.png" class="w-full rounded-xl aspect-square object-cover opacity-90">
                  <p class="text-white text-[8px] sm:text-[8px] text-center mt-2 leading-tight font-bold">PUBG
                  </p>
                </div>
              </a>
              <% } %>

              <% if (hasType('mcgg')) { %>
              <a href="/shop/mcgg" class="group">
                <div
                  class="relative rounded-2xl p-2 bg-white/10 backdrop-blur-lg border border-white/20 shadow-md shadow-blue-900/25 hover:scale-105 transition-transform duration-300 h-full">
                  <img src="/images/mcgg.png" class="w-full rounded-xl aspect-square object-cover">
                  <p class="text-white text-[8px] sm:text-[8px] text-center mt-2 leading-tight font-bold">Magic Chess Go
                    Go</p>
                </div>
              </a>
              <% } %>

              <% if (hasType('hok')) { %>
              <a href="/shop/hok" class="group">
                <div
                  class="relative rounded-2xl p-2 bg-white/10 backdrop-blur-lg border border-white/20 shadow-md shadow-blue-900/25 hover:scale-105 transition-transform duration-300 h-full">
                  <img src="/images/hok.png" class="w-full rounded-xl aspect-square object-cover">
                  <p class="text-white text-[8px] sm:text-[8px] text-center mt-2 leading-tight font-bold">Honor of Kings
                  </p>
                </div>
              </a>
              <% } %>

            </div>
            <% } else { %>
              <% } %>
        </div>

        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mt-64 md:mt-16">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-white">
              <%= __('guide.title') || 'လမ်းညွှန်' %>
            </h2>
            
            <div class="w-20 h-1 bg-theme-400 mx-auto mt-4 rounded-full"></div>
          </div>

          <div class="grid sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

            <!-- Step 1 -->
            <div
              class="relative p-6 md:p-8 rounded-3xl bg-white/5 backdrop-blur-xl border border-white/10 hover:border-theme-400/40 transition-all duration-300 hover:-translate-y-2 group">

              <div
                class="absolute -top-5 left-6 w-10 h-10 rounded-full bg-theme-500 text-white flex items-center justify-center font-bold text-lg shadow-lg shadow-theme-500/30">
                1
              </div>

              <h3 class="text-xl md:text-2xl font-bold text-white mt-6 mb-4">
                <%= __('guide.step1_title') || 'Diamond Top-up' %>
              </h3>


              <div class="aspect-video rounded-xl overflow-hidden border border-white/10">
                <iframe class="w-full h-full" src="https://www.youtube.com/embed/13FCkujoQi8" title="Guide Video 1"
                  allowfullscreen>
                </iframe>
              </div>
            </div>

            <!-- Step 2 -->
            <div
              class="relative p-6 md:p-8 rounded-3xl bg-white/5 backdrop-blur-xl border border-white/10 hover:border-theme-400/40 transition-all duration-300 hover:-translate-y-2 group">

              <div
                class="absolute -top-5 left-6 w-10 h-10 rounded-full bg-theme-500 text-white flex items-center justify-center font-bold text-lg shadow-lg shadow-theme-500/30">
                2
              </div>

              <h3 class="text-xl md:text-2xl font-bold text-white mt-6 mb-4">
                <%= __('guide.step2_title') || 'Wallet Top-up' %>
              </h3>

              <div class="aspect-video rounded-xl overflow-hidden border border-white/10">
                <iframe class="w-full h-full" src="https://www.youtube.com/embed/GoJKpEvtsLc" title="Guide Video 2"
                  allowfullscreen>
                </iframe>
              </div>
            </div>

            <!-- Step 3 -->
            <div
              class="relative p-6 md:p-8 rounded-3xl bg-white/5 backdrop-blur-xl border border-white/10 hover:border-theme-400/40 transition-all duration-300 hover:-translate-y-2 group">

              <div
                class="absolute -top-5 left-6 w-10 h-10 rounded-full bg-theme-500 text-white flex items-center justify-center font-bold text-lg shadow-lg shadow-theme-500/30">
                3
              </div>

              <h3 class="text-xl md:text-2xl font-bold text-white mt-6 mb-4">
                <%= __('guide.step3_title') || 'Diamond Top-up' %>
              </h3>

              <div class="aspect-video rounded-xl overflow-hidden border border-white/10">
                <iframe class="w-full h-full" src="https://www.youtube.com/embed/I8AECgNhcew" title="Guide Video 3"
                  allowfullscreen>
                </iframe>
              </div>
            </div>

          </div>
        </div>



      </div>


    </section>


    <script>
      let index = 0;
      setInterval(() => {
        index = (index + 1) % 3;
        const slider = document.getElementById('slider');
        if (slider) slider.style.transform = `translateX(-${index * 100}%)`;
      }, 3000);
    </script>

    <%- include('../partials/ml-footer') %>
      <%- include('../partials/ml-scripts') %>
        <%- include('../partials/ml-floating-nav') %>
</body>

</html>