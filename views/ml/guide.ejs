<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: 'Guide - ATOM Game Shop' ,
    description: 'Step-by-step guide for wallet top-up and diamond purchases on ATOM Game Shop.'
    }) %>
  <style>
    .video-container {
      position: relative;
      width: 100%;
      height: 0;
      padding-bottom: 56.25%;
      /* 16:9 aspect ratio */
      background: rgba(0, 0, 0, 0.1);
      border-radius: 12px;
      overflow: hidden;
    }

    .video-container iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: none;
    }

    .video-container video {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .guide-card {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 16px;
      transition: all 0.3s ease;
    }

    .guide-card:hover {
      transform: translateY(-5px);
      background: rgba(255, 255, 255, 0.15);
      border-color: rgba(148, 180, 211, 0.4);
    }

    .step-number {
      background: linear-gradient(135deg, #3b82f6, #1d4ed8);
      color: white;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 18px;
      margin-bottom: 16px;
    }
  </style>
</head>

<body class="bg-gray-50 font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>

  <!-- Guide Section -->
  <section class="relative min-h-screen pt-20 pb-16">
    <!-- Modern Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
    </div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" style="max-width: 1400px;">
      <!-- Header -->
      <div class="text-center mb-12 animate-fade-in">
        <% if (currentLanguage==='mm' ) { %>
        <h1 class="text-3xl md:text-5xl font-bold myanmar-text text-white mb-4" style="text-shadow: 0 2px 8px #2563eb; white-space: nowrap;">
          <%= __('guide.title') || 'လမ်းညွှန်' %>
        </h1>
        <p class="text-lg myanmar-text text-gray-200 max-w-3xl mx-auto" style="text-shadow: 0 1px 4px #2563eb;">
          <%= __('guide.subtitle') || 'ပိုက်ဆံအိတ်ဖြည့်ခြင်းနှင့် စိန်ဝယ်ယူခြင်းအတွက် အဆင့်ဆင့်လမ်းညွှန်' %>
        </p>
        <% } else { %>
        <h1 class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent mb-4">
          <%= __('guide.title') || 'How-to Guide' %>
        </h1>
        <p class="text-lg text-gray-300 max-w-3xl mx-auto">
          <%= __('guide.subtitle') || 'Step-by-step guide for wallet top-up and diamond purchases' %>
        </p>
        <% } %>
      </div>

      <!-- Guide Videos -->
      <div class="grid lg:grid-cols-3 gap-5 mb-12">

        <!-- Step 1: Activate Account -->
        <div class="guide-card p-8 animate-slide-up" style="animation-delay: 0.2s;">
          <div class="step-number">1</div>
          <h3 class="text-2xl font-bold text-white mb-4">
            <%= __('guide.step1_title') || 'Diamond Top-up' %>
          </h3>


          <div class="video-container mb-4">
            <iframe src="https://www.youtube.com/embed/13FCkujoQi8?si=DPU9Cjj_SoOvzIUp" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
          </div>

        </div>

        <!-- Step 2: Wallet Top-up -->
        <div class="guide-card p-8 animate-slide-up">
          <div class="step-number">2</div>
          <h3 class="text-2xl font-bold text-white mb-4">
            <%= __('guide.step2_title') || 'Wallet Top-up' %>
          </h3>

          <div class="video-container mb-4">
            <iframe src="https://www.youtube.com/embed/GoJKpEvtsLc?si=gDiLk_ecuNjpue-8" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
          </div>
        </div>

        <!-- Step 3: Diamond Top-up -->
        <div class="guide-card p-8 animate-slide-up" style="animation-delay: 0.2s;">
          <div class="step-number">3</div>
          <h3 class="text-2xl font-bold text-white mb-4">
            <%= __('guide.step3_title') || 'Diamond Top-up' %>
          </h3>

          <div class="video-container mb-4">
            <iframe src="https://www.youtube.com/embed/I8AECgNhcew?si=F-cvXHgiU9Uhr0i5" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
          </div>

        </div>


      </div>

      <!-- Additional Tips -->
      <div class="bg-gradient-to-r from-theme-600/20 to-theme-800/20 backdrop-blur-md rounded-2xl p-8 border border-theme-500/30 animate-slide-up" style="animation-delay: 0.4s;">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6 text-center flex items-center justify-center">
          <span class="text-3xl mr-3">💡</span>
          <%= __('guide.tips_title') || 'Pro Tips' %>
        </h2>

        <div class="grid md:grid-cols-2 gap-6">
          <!-- Tip 1 -->
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
            <div class="flex items-start space-x-4">
              <span class="text-2xl">⚡</span>
              <div>
                <h3 class="text-lg font-semibold text-theme-300 mb-2">
                  <%= __('guide.tip1_title') || 'Fast Processing' %>
                </h3>
                <p class="text-gray-300 text-sm">
                  <%= __('guide.tip1_desc') || 'Diamonds are delivered instantly after successful payment confirmation.' %>
                </p>
              </div>
            </div>
          </div>

          <!-- Tip 2 -->
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
            <div class="flex items-start space-x-4">
              <span class="text-2xl">🔒</span>
              <div>
                <h3 class="text-lg font-semibold text-theme-300 mb-2">
                  <%= __('guide.tip2_title') || 'Secure Transactions' %>
                </h3>
                <p class="text-gray-300 text-sm">
                  <%= __('guide.tip2_desc') || 'All transactions are encrypted and processed through secure payment gateways.' %>
                </p>
              </div>
            </div>
          </div>

          <!-- Tip 3 -->
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
            <div class="flex items-start space-x-4">
              <span class="text-2xl">📱</span>
              <div>
                <h3 class="text-lg font-semibold text-theme-300 mb-2">
                  <%= __('guide.tip3_title') || 'Mobile Friendly' %>
                </h3>
                <p class="text-gray-300 text-sm">
                  <%= __('guide.tip3_desc') || 'Access our platform from any device - desktop, tablet, or mobile.' %>
                </p>
              </div>
            </div>
          </div>

          <!-- Tip 4 -->
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
            <div class="flex items-start space-x-4">
              <span class="text-2xl">🎮</span>
              <div>
                <h3 class="text-lg font-semibold text-theme-300 mb-2">
                  <%= __('guide.tip4_title') || 'Game Ready' %>
                </h3>
                <p class="text-gray-300 text-sm">
                  <%= __('guide.tip4_desc') || 'Double-check your Mobile Legends ID and Zone before purchasing.' %>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Call to Action -->
      <div class="text-center mt-12 animate-slide-up" style="animation-delay: 0.6s;">
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-8 border border-white/20">
          <h3 class="text-2xl font-bold text-white mb-4">
            <%= __('guide.cta_title') || 'Ready to Get Started?' %>
          </h3>
          <p class="text-gray-300 mb-6">
            <%= __('guide.cta_desc') || 'Follow these simple steps and start enjoying your Mobile Legends diamonds!' %>
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/shop" class="bg-gradient-to-r from-theme-600 to-theme-700 hover:from-theme-700 hover:to-theme-800 text-white px-8 py-3 rounded-xl font-semibold transition-all duration-300 transform hover:scale-105 shadow-lg">
              <%= __('guide.shop_now') || 'Shop Now' %>
            </a>
            <a href="https://t.me/atomgameshop" class="bg-white/10 hover:bg-white/20 text-white px-8 py-3 rounded-xl font-semibold transition-all duration-300 border border-white/20 hover:border-white/40">
              <%= __('guide.need_help') || 'Need Help?' %>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%- include('../partials/ml-scripts') %>

  <script>
    // Add smooth scrolling and video interaction
    document.addEventListener('DOMContentLoaded', function() {
      // Pause other videos when one starts playing
      const videos = document.querySelectorAll('video');
      videos.forEach(video => {
        video.addEventListener('play', function() {
          videos.forEach(otherVideo => {
            if (otherVideo !== video) {
              otherVideo.pause();
            }
          });
        });
      });

      // Add loading states for videos
      videos.forEach(video => {
        video.addEventListener('loadstart', function() {
          this.parentElement.style.background = 'rgba(0, 0, 0, 0.2)';
        });

        video.addEventListener('canplay', function() {
          this.parentElement.style.background = 'rgba(0, 0, 0, 0.1)';
        });
      });
    });
  </script>
 
  <%- include('../partials/ml-scripts') %>
   <%- include('../partials/ml-floating-nav') %>
</body>

</html>