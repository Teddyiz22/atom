  <!-- Toast Messages from Server -->
  <script>
    // Check for success message
    const urlParams = new URLSearchParams(window.location.search);
    const successMsg = urlParams.get('success');
    const errorMsg = urlParams.get('error');

    if (successMsg) {
      showSuccessToast(decodeURIComponent(successMsg));
      // Clean URL
      window.history.replaceState({}, document.title, window.location.pathname);
    }

    if (errorMsg) {
      showErrorToast(decodeURIComponent(errorMsg));
      // Clean URL
      window.history.replaceState({}, document.title, window.location.pathname);
    }

    // Auto-refresh wallet balance
    async function refreshWalletBalance() {
      try {
        // Show loading state
        const mmkBalance = document.querySelector('.mmk-balance');
        const thbBalance = document.querySelector('.thb-balance');

        if (mmkBalance) mmkBalance.innerHTML = '<span class="animate-pulse">Loading...</span>';
        if (thbBalance) thbBalance.innerHTML = '<span class="animate-pulse">Loading...</span>';

        const response = await fetch('/wallet/api/balance');
        if (response.ok) {
          const data = await response.json();

          // Update MMK balance
          if (mmkBalance) {
            mmkBalance.textContent = data.balance_mmk.toLocaleString();
          }

          // Update THB balance
          if (thbBalance) {
            thbBalance.textContent = data.balance_thb.toLocaleString();
          }

          console.log('💰 Wallet balance refreshed:', data);
        } else {
          console.error('Failed to refresh wallet balance');
          // Restore original values on error
          if (mmkBalance) mmkBalance.textContent = '0';
          if (thbBalance) thbBalance.textContent = '0';
        }
      } catch (error) {
        console.error('Error refreshing wallet balance:', error);
        // Restore original values on error
        const mmkBalance = document.querySelector('.mmk-balance');
        const thbBalance = document.querySelector('.thb-balance');
        if (mmkBalance) mmkBalance.textContent = '0';
        if (thbBalance) thbBalance.textContent = '0';
      }
    }

    // Load balance immediately when page loads
    document.addEventListener('DOMContentLoaded', function() {
      console.log('🔄 Loading wallet balance on page load...');
      // Small delay to ensure DOM is fully rendered
      setTimeout(refreshWalletBalance, 100);
    });

    // Refresh balance every 30 seconds
    setInterval(refreshWalletBalance, 30000);

    // Manual refresh function
    window.refreshBalance = function() {
      console.log('🔄 Manual balance refresh triggered');
      refreshWalletBalance();
      showSuccessToast('💰 Balance refreshed!');
    };

    // Focus-based refresh (when user returns to tab)
    document.addEventListener('visibilitychange', function() {
      if (!document.hidden) {
        console.log('🔄 Tab focus refresh triggered');
        refreshWalletBalance();
      }
    });
  </script>
