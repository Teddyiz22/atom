<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: __('disclaimer.title') + ' - ATOM Game Shop',
    description: 'Disclaimer for ATOM Game Shop services.' }) %>
</head>

<body class="bg-gray-50 font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>

  <!-- Section -->
  <section class="relative pt-20 pb-16 min-h-screen">
    <!-- Modern Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
    </div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
    </div>

    <!-- Hero Section -->
    <div class="relative z-10 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="animate-fade-in">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-yellow-500/10 border border-yellow-500/30 mb-6 animate-pulse-slow">
            <svg class="w-8 h-8 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <h1 class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent mb-6">
            <%= __('disclaimer.title') %>
          </h1>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="bg-gray-900/60 backdrop-blur-xl rounded-3xl shadow-2xl p-8 md:p-12 border border-white/10 animate-slide-up">
        
        <!-- Main Disclaimer Alert -->
        <div class="bg-yellow-500/5 border-l-4 border-yellow-500 p-6 rounded-r-xl mb-10 transition-transform hover:scale-[1.01] duration-300">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-medium text-yellow-500 mb-2">Important Notice</h3>
              <p class="text-gray-300 leading-relaxed text-base md:text-lg"><%= __('disclaimer.main') %></p>
            </div>
          </div>
        </div>

        <!-- Third Party Links Section -->
        <div class="space-y-6">
          <div class="flex items-center space-x-3 mb-4">
            <div class="p-2 bg-blue-500/10 rounded-lg">
              <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-white"><%= __('disclaimer.third_party_title') %></h3>
          </div>
          
          <div class="prose prose-invert max-w-none text-gray-400 bg-white/5 rounded-2xl p-6 border border-white/5">
            <p><%= __('disclaimer.third_party_content') %></p>
          </div>
        </div>

        <!-- Footer Info -->
        <div class="mt-12 pt-6 border-t border-white/10 flex items-center text-sm text-gray-500">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <%= __('disclaimer.last_updated') %>: <%= new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </div>

      </div>
    </div>
  </section>

  <%- include('../partials/ml-footer') %>
  <%- include('../partials/ml-scripts') %>
</body>

</html>
