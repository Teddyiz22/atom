          <div class="w-full flex-shrink-0">
            <img src="/images/banner.png"  
                class="w-full aspect-[16/9] object-contain bg-black">
          </div>
          
        </div>
      </div>


  </div>

      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <% if (typeof mode !== 'undefined' && mode === 'types') { %>
