</div>
        <% } else { %>
          <% } %>
      </div> </div> </section>

  <script>
    let index = 0;
    setInterval(() => {
      index = (index + 1) % 3;
      const slider = document.getElementById('slider');
      if(slider) slider.style.transform = `translateX(-${index * 100}%)`;
    }, 3000);
  </script>
  
  <%- include('../partials/ml-footer') %>
  <%- include('../partials/ml-scripts') %>
  <%- include('../partials/ml-floating-nav') %>
</body>
</html>