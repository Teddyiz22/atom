<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: 'ATOM Game Shop - Fast & Secure Mobile Legends Top Up' ,
    description: 'Buy Mobile Legends diamonds instantly! Fast, secure, and affordable ML diamond top-up service. Get your diamonds in seconds!'
    }) %>
