            <button class="px-5 py-2 rounded-full text-white text-sm bg-white/20 backdrop-blur-md border border-white/30 shadow-lg shadow-blue-500/30 hover:bg-white/30 transition">Popular</button>
            <button class="px-5 py-2 rounded-full text-white text-sm bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 transition">All Games</button>
          </div>

          <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 px-4 mt-6 font-mont max-w-5xl mx-auto">
  
  <a href="/shop/ml" class="group">
    <div class="relative rounded-2xl p-2 bg-white/10 backdrop-blur-lg border border-white/20 shadow-md shadow-blue-900/25 hover:scale-105 transition-transform duration-300 h-full">
      <img src="/images/mlbb_special.png" class="w-full rounded-xl aspect-square object-cover">
      <p class="text-white text-[10px] sm:text-xs text-center mt-2 leading-tight font-medium">Mobile Legends</p>
      <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-white/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
