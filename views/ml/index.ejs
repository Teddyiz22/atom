    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"></div>

    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="particle particle-1"></div>
      <div class="particle particle-2"></div>
      <div class="particle particle-3"></div>
      <div class="particle particle-4"></div>
      <div class="particle particle-5"></div>
      <div class="particle particle-6"></div>
    </div>

    <div class="absolute top-40 left-[-5%] w-64 h-64 bg-theme-400/10 blur-[100px] rounded-full animate-float-slow"></div>
    <div class="absolute bottom-40 right-[-5%] w-48 h-48 bg-theme-500/10 blur-[80px] rounded-full animate-float-delay"></div>
    <div class="absolute top-1/2 left-10 w-32 h-32 bg-theme-300/10 blur-[60px] rounded-full animate-float"></div>

    <div class="relative z-10">
      
      <div class="max-w-6xl mx-auto p-4 md:p-8"> 
  
