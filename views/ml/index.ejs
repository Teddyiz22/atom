<body class="bg-gray-50 font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>



  <!-- Include Toast System -->
  <%- include('../partials/toast') %>

  <!-- Handle Success Messages -->
  <% if (typeof successData !=='undefined' && successData.message) { %>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const message = '<%= successData.message %>';
      const isRegistration = <%= successData.isRegistration %>;
      const isLogin = <%= successData.isLogin %>;

      if (isRegistration) {
        showToast(message, 'registration');
      } else if (isLogin) {
        showToast(message, 'login');
      } else {
        showSuccessToast(message);
      }
    });
  </script>
  <% } %>

