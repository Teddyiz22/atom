<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/ml-head', { title: 'FAQ - ATOM Game Shop' ,
    description: 'Frequently asked questions about Mobile Legends diamond purchases, payments, delivery, and account safety.'
    }) %>
    <style>
      .faq-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out;
      }

      .faq-content.active {
        max-height: 500px;
        transition: max-height 0.3s ease-in;
      }
    </style>
</head>

<body class="bg-gray-50 font-sans overflow-x-hidden">
  <%- include('../partials/ml-nav') %>

    <!-- FAQ Section -->
    <section class="relative min-h-screen pt-20 pb-16">
      <!-- Modern Gradient Background -->
      <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
      </div>

      <!-- Content -->
      <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="text-center mb-12 animate-fade-in">
          <% if (currentLanguage==='mm' ) { %>
            <h1 class="text-3xl md:text-5xl font-bold myanmar-text myanmar-line text-white"
              style="text-shadow: 0 2px 8px #2563eb;">
              <%= __('faq.title') %>
            </h1>
            <p class="text-lg myanmar-text myanmar-line text-gray-200 max-w-3xl mx-auto"
              style="text-shadow: 0 1px 4px #2563eb;">
              <%= __('faq.subtitle') %>
            </p>
            <% } else { %>
              <h1
                class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent mb-4">
                <%= __('faq.title') %>
              </h1>
              <p class="text-lg text-gray-300 max-w-3xl mx-auto">
                <%= __('faq.subtitle') %>
              </p>
              <% } %>
        </div>

        <!-- Quick Search -->
        <div class="mb-8 animate-slide-up">
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20">
            <div class="flex items-center space-x-3">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <input type="text" id="faqSearch" placeholder="<%= __('faq.search_placeholder') %>"
                class="flex-1 bg-transparent text-white placeholder-white/60 focus:outline-none text-lg">
            </div>
          </div>
        </div>

        <!-- Why Choose ATOM Game Shop -->
        <div class="mb-12 animate-slide-up">
          <div
            class="bg-gradient-to-r from-theme-600/20 to-theme-800/20 backdrop-blur-md rounded-2xl p-8 border border-theme-500/30">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-6 text-center flex items-center justify-center">
              <span class="text-3xl mr-3">⭐</span>
              <%= __('faq.why_choose_title') %>
            </h2>

            <div class="grid md:grid-cols-2 gap-6">
              <!-- Reason 1 -->
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
                <div class="flex items-start space-x-4">
                  <span class="text-2xl">✨</span>
                  <div>
                    <h3 class="text-lg font-semibold text-theme-300 mb-2">
                      <%= __('faq.reason_1_title') %>
                    </h3>
                    <p class="text-gray-300 text-sm">
                      <%= __('faq.reason_1_desc') %>
                    </p>
                  </div>
                </div>
              </div>

              <!-- Reason 2 -->
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
                <div class="flex items-start space-x-4">
                  <span class="text-2xl">⚡</span>
                  <div>
                    <h3 class="text-lg font-semibold text-theme-300 mb-2">
                      <%= __('faq.reason_2_title') %>
                    </h3>
                    <p class="text-gray-300 text-sm">
                      <%= __('faq.reason_2_desc') %>
                    </p>
                  </div>
                </div>
              </div>

              <!-- Reason 3 -->
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
                <div class="flex items-start space-x-4">
                  <span class="text-2xl">🎮</span>
                  <div>
                    <h3 class="text-lg font-semibold text-theme-300 mb-2">
                      <%= __('faq.reason_3_title') %>
                    </h3>
                    <p class="text-gray-300 text-sm">
                      <%= __('faq.reason_3_desc') %>
                    </p>
                  </div>
                </div>
              </div>

              <!-- Reason 4 -->
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
                <div class="flex items-start space-x-4">
                  <span class="text-2xl">💯</span>
                  <div>
                    <h3 class="text-lg font-semibold text-theme-300 mb-2">
                      <%= __('faq.reason_4_title') %>
                    </h3>
                    <p class="text-gray-300 text-sm">
                      <%= __('faq.reason_4_desc') %>
                    </p>
                  </div>
                </div>
              </div>

              <!-- Reason 5 -->
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20 md:col-span-2">
                <div class="flex items-start space-x-4">
                  <span class="text-2xl">🎯</span>
                  <div>
                    <h3 class="text-lg font-semibold text-theme-300 mb-2">
                      <%= __('faq.reason_5_title') %>
                    </h3>
                    <p class="text-gray-300 text-sm">
                      <%= __('faq.reason_5_desc') %>
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-8 text-center">
              <p class="text-lg text-white mb-4">
                <%= __('faq.conclusion') %>
              </p>
              <p class="text-theme-300 font-medium">
                <%= __('faq.guarantee') %>
              </p>
            </div>
          </div>
        </div>

        <!-- FAQ Categories -->
        <div class="grid md:grid-cols-2 gap-8">

          <!-- Getting Started -->
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20 animate-slide-up">
            <h2 class="text-xl md:text-2xl font-bold text-white mb-6 flex items-center">
              <span
                class="bg-gradient-to-r from-theme-400 to-theme-600 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mr-3">🚀</span>
              <%= __('faq.category_getting_started') %>
            </h2>

            <!-- FAQ Item 1 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">How do I buy Mobile Legends diamonds?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">Buying diamonds is easy and takes just a few steps:</p>
                  <ol class="list-decimal list-inside space-y-2">
                    <li>Enter your Mobile Legends User ID and Zone ID</li>
                    <li>Select your desired diamond package</li>
                    <li>Choose your payment method</li>
                    <li>Complete the payment</li>
                    <li>Diamonds will be delivered instantly to your account!</li>
                  </ol>
                </div>
              </div>
            </div>

            <!-- FAQ Item 2 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">How do I find my User ID and Zone ID?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">To find your User ID and Zone ID:</p>
                  <ol class="list-decimal list-inside space-y-2">
                    <li>Open Mobile Legends: Bang Bang</li>
                    <li>Tap on your avatar in the top-left corner</li>
                    <li>Your User ID and Zone ID will be displayed</li>
                    <li>Format: User ID (Zone ID) - Example: 123456789 (1234)</li>
                  </ol>
                  <p class="mt-3 text-theme-300">💡 Make sure to enter both numbers correctly!</p>
                </div>
              </div>
            </div>

            <!-- FAQ Item 3 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">Is it safe to buy diamonds from your store?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">Yes, absolutely! Your account safety is our top priority:</p>
                  <ul class="list-disc list-inside space-y-2">
                    <li>We use official Moonton top-up methods</li>
                    <li>We never ask for your account password</li>
                    <li>All transactions are secured with SSL encryption</li>
                    <li>We have 99.9% success rate with no account bans</li>
                    <li>Over 50,000 satisfied customers trust our service</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Payment & Delivery -->
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20 animate-slide-up">
            <h2 class="text-xl md:text-2xl font-bold text-white mb-6 flex items-center">
              <span
                class="bg-gradient-to-r from-theme-400 to-theme-600 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mr-3">💳</span>
              <%= __('faq.category_payment_delivery') %>
            </h2>

            <!-- FAQ Item 4 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">What payment methods do you accept?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">We accept multiple payment methods for your convenience:</p>
                  <ul class="list-disc list-inside space-y-2">
                    <li>🏦 Local Bank Transfers (KBZ, CB, AYA, UAB)</li>
                    <li>📱 Mobile Banking (KBZ Pay, CB Pay, AYA Pay)</li>
                    <li>💳 Credit/Debit Cards (Visa, Mastercard)</li>
                    <li>🌐 Digital Wallets (PayPal, Wave Money)</li>
                    <li>💰 Cryptocurrency (Bitcoin, USDT)</li>
                  </ul>
                  <p class="mt-3 text-theme-300">💡 All payments are processed securely!</p>
                </div>
              </div>
            </div>

            <!-- FAQ Item 5 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">How long does delivery take?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">We pride ourselves on instant delivery:</p>
                  <ul class="list-disc list-inside space-y-2">
                    <li>⚡ Normal packages: 1-5 minutes</li>
                    <li>📅 Weekly Pass: 5-10 minutes</li>
                    <li>🎯 99% of orders delivered within 5 minutes</li>
                    <li>🔄 Automatic processing 24/7</li>
                    <li>📞 Live support if any delays occur</li>
                  </ul>
                  <p class="mt-3 text-theme-300">✅ Most customers receive diamonds instantly!</p>
                </div>
              </div>
            </div>

            <!-- FAQ Item 6 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">Can I get a refund if I made a mistake?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">We understand mistakes happen. Our refund policy:</p>
                  <ul class="list-disc list-inside space-y-2">
                    <li>✅ Full refund if diamonds not delivered within 24 hours</li>
                    <li>✅ Partial refund for wrong User ID (if not yet processed)</li>
                    <li>✅ Account credit for technical issues on our end</li>
                    <li>❌ No refund after successful delivery to correct account</li>
                    <li>💬 Contact support immediately for any issues</li>
                  </ul>
                  <p class="mt-3 text-theme-300">⚠️ Always double-check your User ID before ordering!</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Technical Issues -->
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20 animate-slide-up">
            <h2 class="text-xl md:text-2xl font-bold text-white mb-6 flex items-center">
              <span
                class="bg-gradient-to-r from-theme-400 to-theme-600 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mr-3">🔧</span>
              <%= __('faq.category_technical_issues') %>
            </h2>

            <!-- FAQ Item 7 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">I paid but didn't receive my diamonds. What should I do?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">Don't worry! Please follow these steps:</p>
                  <ol class="list-decimal list-inside space-y-2">
                    <li>Wait 10-15 minutes as some deliveries may be delayed</li>
                    <li>Check if you entered the correct User ID and Zone ID</li>
                    <li>Restart your Mobile Legends app</li>
                    <li>Contact our support with your transaction details</li>
                    <li>Provide payment proof and order number</li>
                  </ol>
                  <p class="mt-3 text-theme-300">📞 Our support team will resolve this within 1 hour!</p>
                </div>
              </div>
            </div>

            <!-- FAQ Item 8 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">Why is the website not loading properly?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">Try these troubleshooting steps:</p>
                  <ul class="list-disc list-inside space-y-2">
                    <li>Clear your browser cache and cookies</li>
                    <li>Try using a different browser (Chrome, Firefox, Safari)</li>
                    <li>Check your internet connection</li>
                    <li>Disable ad blockers temporarily</li>
                    <li>Try accessing from mobile if on desktop (or vice versa)</li>
                  </ul>
                  <p class="mt-3 text-theme-300">💡 Still having issues? Contact our technical support!</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Account & Packages -->
          <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/20 animate-slide-up">
            <h2 class="text-xl md:text-2xl font-bold text-white mb-6 flex items-center">
              <span
                class="bg-gradient-to-r from-theme-400 to-theme-600 text-white w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold mr-3">👤</span>
              <%= __('faq.category_account_packages') %>
            </h2>

            <!-- FAQ Item 9 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">What's the difference between diamonds and Weekly Pass?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">Here's the difference:</p>
                  <div class="space-y-3">
                    <div class="bg-white/5 p-3 rounded-lg">
                      <h4 class="text-theme-300 font-medium mb-2">💎 Diamonds</h4>
                      <p>Instant diamonds added to your account immediately. Use for skins, heroes, and in-game
                        purchases.
                      </p>
                    </div>
                    <div class="bg-white/5 p-3 rounded-lg">
                      <h4 class="text-theme-300 font-medium mb-2">📅 Weekly Pass</h4>
                      <p>Special package with instant diamonds + daily rewards over 7 days. Includes bonus items like
                        Starlight Scores and Diamond Bundle Passes. Account must be level 5+.</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- FAQ Item 10 -->
            <div class="mb-4">
              <button
                class="faq-question w-full text-left p-4 bg-white/5 hover:bg-white/10 rounded-lg border border-white/10 transition-all duration-300"
                onclick="toggleFAQ(this)">
                <div class="flex justify-between items-center">
                  <span class="text-white font-medium">Do you offer discounts or bonus diamonds?</span>
                  <svg class="w-5 h-5 text-gray-400 transform transition-transform duration-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </button>
              <div class="faq-content">
                <div class="p-4 text-gray-300 text-sm leading-relaxed">
                  <p class="mb-3">Yes! We have several ways to save:</p>
                  <ul class="list-disc list-inside space-y-2">
                    <li>🎁 First-time purchase bonus (double diamonds at certain levels)</li>
                    <li>💯 Bulk purchase discounts for larger packages</li>
                    <li>🎉 Special holiday promotions and events</li>
                    <li>💸 Loyalty rewards for frequent customers</li>
                    <li>📢 Follow our social media for exclusive deals</li>
                  </ul>
                  <p class="mt-3 text-theme-300">✨ Check our homepage for current promotions!</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Still Need Help -->
        <div class="mt-12 text-center animate-slide-up">
          <div
            class="bg-gradient-to-r from-theme-600/20 to-theme-800/20 backdrop-blur-md rounded-2xl p-8 border border-theme-500/30">
            <h3 class="text-2xl font-bold text-white mb-4">
              <%= __('faq.still_need_help') %>
            </h3>
            <p class="text-gray-300 mb-6">
              <%= __('faq.still_need_help_desc') %>
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/contact"
                class="bg-gradient-to-r from-theme-600 to-theme-800 text-white px-8 py-3 rounded-lg font-medium hover:from-theme-700 hover:to-theme-900 transition-all duration-300 transform hover:scale-105">
                <%= __('faq.contact_support') %>
              </a>
              <a href="https://t.me/atomgameshop" target="_blank"
                class="bg-white/10 border border-white/30 text-white px-8 py-3 rounded-lg font-medium hover:bg-white/20 transition-all duration-300 flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                  <path
