<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> - ATOM Game Shop
  </title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Custom ML CSS -->
  <link rel="stylesheet" href="/css/ml-styles.css">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#38B6FF',
            secondary: '#2493D4',
            accent: '#353535',
            post: '#94B4D3',
            theme: {
              50: '#e6f7ff',
              100: '#b3e9ff',
              200: '#80dbff',
              300: '#4dcdff',
              400: '#38B6FF',
              500: '#2493D4',
              600: '#1f7db8',
              700: '#1a679c',
              800: '#155180',
              900: '#353535',
              950: '#2a2a2a'
            }
          }
        }
      }
    }
  </script>
</head>

<body class="bg-gray-50 font-sans">
  <!-- Navigation -->
  <nav class="bg-black/10 backdrop-blur-md border-b border-white/10 fixed w-full top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center">
          <a href="/" class="text-xl md:text-2xl font-bold text-theme-300">
            💎 ML Diamonds
          </a>
        </div>
        <div class="flex items-center space-x-4">
          <a href="/" class="text-white/80 hover:text-theme-300 px-3 py-2 rounded-md text-sm font-medium">Home</a>
          <a href="/order" class="bg-theme-400/20 text-theme-300 px-4 py-2 rounded-full text-sm font-medium">Order
            Now</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- 404 Error Content -->
  <section class="relative pt-20 pb-16 min-h-screen">
    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-theme-900 via-theme-800 to-theme-950"></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(148,180,211,0.3),rgba(255,255,255,0))]">
    </div>

    <div class="relative z-10 flex items-center justify-center min-h-screen">
      <div class="text-center px-4">
        <!-- 404 Icon -->
        <div class="mb-8">
          <div
            class="inline-flex items-center justify-center w-32 h-32 bg-theme-400/20 rounded-full border border-theme-400/30">
            <svg class="w-16 h-16 text-theme-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M9.172 16.172a4 4 0 015.656 0M9 12h6m-6-4h6M7 8.5V6a4 4 0 014-4h2a4 4 0 014 4v2.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
              </path>
            </svg>
          </div>
        </div>

        <!-- Error Message -->
        <h1 class="text-6xl md:text-8xl font-bold text-white mb-4">404</h1>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">Page Not Found</h2>
        <p class="text-lg text-gray-300 mb-8 max-w-md mx-auto">
          <%= message || "The page you are looking for doesn't exist or has been moved." %>
        </p>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/"
            class="bg-theme-400/20 backdrop-blur-sm border border-theme-400/30 text-theme-300 px-8 py-3 rounded-full font-medium hover:bg-theme-400/30 hover:border-theme-400/50 transition-all duration-300">
            🏠 Go Home
          </a>
          <a href="/order"
            class="bg-theme-500/20 backdrop-blur-sm border border-theme-500/30 text-white px-8 py-3 rounded-full font-medium hover:bg-theme-500/30 hover:border-theme-500/50 transition-all duration-300">
            💎 Order Diamonds
          </a>
        </div>

        <% if (typeof showTelegramSupport !== 'undefined' && showTelegramSupport) { %>
        <a href="https://t.me/atomgameshop" target="_blank" rel="noopener noreferrer"
          title="Open Telegram — @atomgameshop"
          aria-label="Open Telegram chat with ATOM Game Shop @atomgameshop"
          class="block max-w-md mx-auto mt-12 text-left rounded-xl cursor-pointer focus:outline-none focus:ring-2 focus:ring-theme-400/50">
          <div
            class="flex items-start space-x-4 p-4 bg-white/10 border border-white/20 rounded-xl backdrop-blur-sm hover:bg-white/15 transition-colors">
            <div
              class="w-12 h-12 bg-gradient-to-br from-theme-500 to-theme-600 rounded-lg flex items-center justify-center flex-shrink-0 pointer-events-none">
              <svg class="w-6 h-6 text-white pointer-events-none" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z">
                </path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-white mb-1">Telegram Support</h3>
              <p class="text-gray-300 text-sm">@atomgameshop</p>
              <p class="text-gray-400 text-sm">Instant messaging support</p>
            </div>
          </div>
        </a>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Scripts -->
  <script src="/js/ml-script.js"></script>
</body>

</html>