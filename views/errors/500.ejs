<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> - ATOM Game Shop
  </title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Custom ML CSS -->
  <link rel="stylesheet" href="/css/ml-styles.css">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#38B6FF',
            secondary: '#2493D4',
            accent: '#353535',
            post: '#94B4D3',
            theme: {
              50: '#e6f7ff',
              100: '#b3e9ff',
              200: '#80dbff',
              300: '#4dcdff',
              400: '#38B6FF',
              500: '#2493D4',
              600: '#1f7db8',
              700: '#1a679c',
              800: '#155180',
              900: '#353535',
              950: '#2a2a2a'
            }
          }
        }
      }
    }
  </script>
</head>

<body class="bg-gray-50 font-sans">
  <!-- Navigation -->
  <nav class="bg-black/10 backdrop-blur-md border-b border-white/10 fixed w-full top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <div class="flex items-center">
          <a href="/" class="text-xl md:text-2xl font-bold text-theme-300">
            💎 ML Diamonds
          </a>
        </div>
        <div class="flex items-center space-x-4">
          <a href="/" class="text-white/80 hover:text-theme-300 px-3 py-2 rounded-md text-sm font-medium">Home</a>
          <a href="/order" class="bg-theme-400/20 text-theme-300 px-4 py-2 rounded-full text-sm font-medium">Order
            Now</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- 500 Error Content -->
  <section class="relative pt-20 pb-16 min-h-screen">
    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-red-900 via-red-800 to-red-950"></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(239,68,68,0.3),rgba(255,255,255,0))]">
    </div>

    <div class="relative z-10 flex items-center justify-center min-h-screen">
      <div class="text-center px-4">
        <!-- 500 Icon -->
        <div class="mb-8">
          <div
            class="inline-flex items-center justify-center w-32 h-32 bg-red-500/20 rounded-full border border-red-500/30">
            <svg class="w-16 h-16 text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.35 16.5c-.77.833.192 2.5 1.732 2.5z">
              </path>
            </svg>
          </div>
        </div>

        <!-- Error Message -->
        <h1 class="text-6xl md:text-8xl font-bold text-white mb-4">500</h1>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">Server Error</h2>
        <p class="text-lg text-gray-300 mb-8 max-w-md mx-auto">
          <%= message || "Something went wrong on our end. We're working to fix it!" %>
        </p>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/"
            class="bg-theme-400/20 backdrop-blur-sm border border-theme-400/30 text-theme-300 px-8 py-3 rounded-full font-medium hover:bg-theme-400/30 hover:border-theme-400/50 transition-all duration-300">
            🏠 Go Home
          </a>
          <button onclick="window.location.reload()"
            class="bg-red-500/20 backdrop-blur-sm border border-red-500/30 text-red-300 px-8 py-3 rounded-full font-medium hover:bg-red-500/30 hover:border-red-500/50 transition-all duration-300">
            🔄 Try Again
          </button>
        </div>

        <!-- Help Text -->
        <div class="mt-12 p-6 bg-white/10 backdrop-blur-md rounded-xl border border-white/20 max-w-md mx-auto">
          <h3 class="text-lg font-semibold text-white mb-2">Technical Difficulties</h3>
          <p class="text-gray-300 text-sm mb-4">
            Our team has been notified and is working to resolve this issue. Please try again in a few minutes.
          </p>
          <div class="flex flex-col space-y-2">
            <a href="/contact" class="text-theme-300 hover:text-theme-200 font-medium text-sm">
              📞 Contact Support
            </a>
            <a href="/faq" class="text-theme-300 hover:text-theme-200 font-medium text-sm">
              ❓ Check FAQ
            </a>
          </div>
        </div>

        <!-- Status Information -->
        <div class="mt-8 text-sm text-gray-400">
          <p>Error ID: <%= Date.now() %>
          </p>
          <p>Time: <%= new Date().toLocaleString('en-US', { timeZone: 'Asia/Yangon' }) %>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Scripts -->
  <script src="/js/ml-script.js"></script>
</body>

</html>